---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap foot-inner">
    <small>© {year} Y.M Apps / PINO</small>
    <nav class="foot-links" aria-label="フッターリンク">
      <a href="/privacy">プライバシーポリシー</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href="/privacy/en">Privacy (EN)</a>
    </nav>
    <img class="foot-cat" src="/assets/pinokun/pinokun-reading-color.png" alt="" loading="lazy" decoding="async" />
  </div>
</footer>

<style>
  .foot-links {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
  .foot-links a { color: var(--ink-3); }
  .foot-links a:hover { color: var(--ink); text-decoration: none; }
  .foot-links .sep { color: var(--ink-3); opacity: 0.55; }
  @media (max-width: 520px) {
    .foot-inner { flex-wrap: wrap; gap: 10px; }
    .foot-links { font-size: 11px; order: 3; flex-basis: 100%; }
  }
</style>
