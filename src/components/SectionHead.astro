---
interface Props {
  title: string;          // text inside the yellow bar
  lede?: string;          // intro paragraph
}

const { title, lede } = Astro.props;
---

<header class="section-head">
  <h2 class="section-title">{title}</h2>
  {lede && <p class="lede">{lede}</p>}
</header>

<style>
  .section-head {
    margin-top: 16px;
    margin-bottom: 10px;
    max-width: 720px;
  }
  .lede {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.85;
    margin: 4px 0 12px;
  }
  @media (max-width: 640px) {
    .lede { margin-bottom: 10px; }
  }
</style>
