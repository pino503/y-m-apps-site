---
// クラフト机風ヘッダー：
// 旧マーキー → 静的な付箋お知らせ。
// ブランド名は左寄せで、テープ装飾を 1 枚添える。
---

<div class="news-strip" aria-label="お知らせ">
  <span class="sticky">📌 BOOX Go7 / Palma 2 Pro レビュー note 公開</span>
  <span class="sticky news-pink">✨ InkPress v1.1.6 配信中</span>
</div>

<header class="site-header">
  <div class="container">
    <a href="/" class="brand" aria-label="Y.M Apps トップへ">
      <span class="tape tape-tl tape-kraft" aria-hidden="true"></span>
      <h1>Y.M Apps</h1>
    </a>
    <nav class="site-nav" aria-label="主要ナビゲーション">
      <a href="/#works">Works</a>
      <a href="/writings">Writings</a>
      <a href="/#about">About</a>
      <a href="/press-kit">Press</a>
      <a href="/#contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  /* 付箋色のバリエーション */
  :global(.news-strip .news-pink) {
    background: #ffd6dd;
    transform: rotate(1.6deg);
  }

  .site-header {
    position: relative;
    text-align: center;
    padding: 12px 0 6px;
  }
  .brand {
    display: inline-block;
    position: relative;
    padding: 10px 18px 8px;
    background: #fffdf7;
    border: 1px solid rgba(140, 110, 70, 0.18);
    border-radius: 6px;
    color: var(--brown-1);
    text-decoration: none;
    box-shadow:
      0 1px 1px rgba(120, 90, 50, 0.06),
      0 4px 10px -6px rgba(120, 90, 50, 0.20);
    transform: rotate(-0.6deg);
    transition: transform 0.25s var(--ease-out-quint);
  }
  .brand:hover {
    text-decoration: none;
    transform: rotate(-0.6deg) translateY(-1px);
  }
  .brand h1 {
    display: inline;
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 0.04em;
  }
  .site-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 14px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .site-nav a {
    color: var(--brown-3);
    padding: 2px 0;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s var(--ease-out-cubic), color 0.2s var(--ease-out-cubic);
  }
  .site-nav a:hover {
    text-decoration: none;
    border-bottom-color: var(--yellow);
    color: var(--brown-1);
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 520px) {
    .site-header { padding: 8px 0 4px; }
    .brand { padding: 8px 14px 6px; }
    .brand h1 { font-size: 19px; letter-spacing: 0.03em; }
    .site-nav {
      gap: 14px;
      margin-top: 10px;
      font-size: 11.5px;
    }
  }
  @media (max-width: 360px) {
    .brand h1 { font-size: 18px; }
    .site-nav { gap: 10px; font-size: 11px; }
  }
</style>
