<header class="site-header">
  <div class="wrap header-inner">
    <a class="brand" href="/" aria-label="Y.M Apps home">
      <span class="brand-mark"><img src="/assets/favicon.png" alt="" /></span>
      <span><span class="brand-name">Y.M Apps</span><span class="brand-by">&nbsp;by PINO</span></span>
    </a>
    <nav class="nav" aria-label="主要ナビゲーション">
      <a href="/#works">Works</a>
      <a href="/writings">Writings</a>
      <a href="/#about">About</a>
      <a href="/#contact">Contact</a>
    </nav>
    <span class="visitors"><span class="lbl">VISITORS</span><span class="num" id="visit-count" data-visitor-count>······</span></span>
  </div>
</header>

<script>
  // ホスト名が「*.pages.dev」または本番カスタムドメインのときだけカウント。
  // ローカル開発・プレビュー環境では水増し防止のため動かさない。
  const host = location.hostname;
  const isProd = host.endsWith(".pages.dev") || host === "y-m-apps.com" || host === "www.y-m-apps.com";
  const el = document.getElementById("visit-count");
  if (el) {
    if (isProd) {
      fetch("https://api.counterapi.dev/v1/y-m-apps-site/visits/up")
        .then((r) => r.json())
        .then((d) => {
          if (d && typeof d.count === "number") {
            el.textContent = String(d.count).padStart(6, "0");
          }
        })
        .catch(() => { el.textContent = "······"; });
    } else {
      el.textContent = "DEV";
    }
  }
</script>
