<!-- レトロな上部バナー：90年代風アクセスカウンター -->
<div class="top-strip">
  <div class="container top-strip-inner">
    <span class="strip-label">VISITORS</span>
    <span class="strip-count" id="visit-count">······</span>
  </div>
</div>

<header class="site-header">
  <div class="container">
    <a href="/" class="brand" aria-label="Y.M Apps トップへ">
      <h1>Y.M Apps</h1>
      <span>by PINO</span>
    </a>
    <nav class="site-nav" aria-label="主要ナビゲーション">
      <a href="/#works">Works</a>
      <a href="/writings">Writings</a>
      <a href="/#about">About</a>
      <a href="/press-kit">Press</a>
      <a href="/#contact">Contact</a>
    </nav>
  </div>
</header>

<script>
  // ホスト名が「*.pages.dev」または本番カスタムドメインのときだけカウント。
  // ローカル開発・プレビュー環境では水増し防止のため動かさない。
  const host = location.hostname;
  const isProd = host.endsWith(".pages.dev") || host === "y-m-apps.com" || host === "www.y-m-apps.com";
  const el = document.getElementById("visit-count");
  if (el) {
    if (isProd) {
      fetch("https://api.counterapi.dev/v1/y-m-apps-site/visits/up")
        .then((r) => r.json())
        .then((d) => {
          if (d && typeof d.count === "number") {
            el.textContent = String(d.count).padStart(6, "0");
          }
        })
        .catch(() => { el.textContent = "······"; });
    } else {
      el.textContent = "DEV";
    }
  }
</script>

