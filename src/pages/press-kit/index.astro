---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHead from "../../components/SectionHead.astro";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Press Kit — Y.M Apps">
  <section class="stack-section">
    <div class="container">
      <SectionHead
        title="Press Kit"
        lede="レビュー記事・媒体掲載・SNS紹介などにご利用ください。出典は「Y.M Apps」または「PINO」と記載いただければ大丈夫です。"
      />

      <h2 class="section-title">プロダクト一覧</h2>

      <div class="card">
        <ul class="ruled-list">
          {apps.map((a) => (
            <li>
              <div>
                <a href={`/works/${a.slug}`}>{a.data.title}</a>
                <p class="summary">{a.data.tagline}</p>
              </div>
              <span class="meta">{a.data.platform}</span>
            </li>
          ))}
        </ul>
      </div>

      <h2 class="section-title">取材のお問い合わせ</h2>

      <div class="card" style="text-align: center;">
        {/* HTML 上にメアド完全形を出さず、JS で組み立てる。
            ボット対策として data 属性に分割して保持。 */}
        <a
          id="press-link"
          class="btn btn-primary"
          href="#"
          data-l="y.m_games503"
          data-d="protonmail.com"
        >
          ✉ メールを送る
        </a>
        <p style="font-size:11.5px;color:var(--brown-4);margin-top:10px;">個別取材・出演・寄稿等のご相談はメールにて。</p>
      </div>
    </div>
  </section>

  <script>
    // ホームの Contact と同じ方式で mailto: を JS 構築
    const link = document.getElementById("press-link") as HTMLAnchorElement | null;
    if (link) {
      const local = link.dataset.l ?? "";
      const domain = link.dataset.d ?? "";
      link.setAttribute("href", `mailto:${local}@${domain}`);
    }
  </script>
</BaseLayout>

<style>
  .press-h { font-size: 15px; font-weight: 900; margin-bottom: 8px; color: var(--brown-1); }
  .press-p { font-size: 12.5px; color: var(--brown-3); margin-bottom: 14px; line-height: 1.85; }
</style>
