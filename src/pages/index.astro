  .omi-rows::before{ content:""; position:absolute; left:22px; right:22px; top:0; height:1px; background:repeating-linear-gradient(90deg,#dcc79a,#dcc79a 5px,transparent 5px,transparent 10px); }
  .omi-row{ display:grid; grid-template-columns:122px 1fr; gap:12px; align-items:center; font-size:13.5px; padding:8px 0; }
  .omi-row + .omi-row{ border-top:1px solid #efe4cc; }
  .omi-row dt{ color:#a8895a; font-weight:700; letter-spacing:.04em; white-space:nowrap; font-family:"Shippori Mincho B1",serif; }
  .omi-row dd{ margin:0; color:#463a26; font-weight:600; display:flex; align-items:center; gap:8px; }
  .omi-stars{ color:var(--gold-deep); letter-spacing:.16em; font-size:15px; }
