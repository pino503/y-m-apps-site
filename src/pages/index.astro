---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import Slot from "../components/Slot.astro";
import Omikuji from "../components/Omikuji.astro";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps")).sort(
  (a, b) => a.data.order - b.data.order
);

// 種類でまとめる。表示順は tool → game → sticker。
const CATEGORY_ORDER = ["tool", "game", "sticker"] as const;
const CATEGORY_LABELS: Record<(typeof CATEGORY_ORDER)[number], { title: string; lede: string }> = {
  tool:    { title: "Tools",    lede: "毎日のちょっとした不便から生まれた道具。" },
  game:    { title: "Games",    lede: "息抜きと挑戦のための、ちいさな遊び。" },
  sticker: { title: "Stickers", lede: "トークの温度を、ちょっとだけ上げる。" },
};
const groupedApps = CATEGORY_ORDER.map((cat) => ({
  cat,
  label: CATEGORY_LABELS[cat],
  items: apps.filter((a) => a.data.category === cat),
})).filter((g) => g.items.length > 0);
// グローバル通し番号: sort 済 apps の中での index を引きたい
const indexOf = new Map(apps.map((a, i) => [a.slug, i]));

const writings = (await getCollection("writings")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const recentWritings = writings.slice(0, 5);
const featured = apps.find((app) => app.slug === "inkpress") ?? apps[0];

// per-app accent color — gives each Works row / Writings tag its own identity
const APP_ACCENT: Record<string, string> = {
  inkpress: "#3d7d8e",
  rainwiper: "#5b8fd6",
  playcord: "#2f8f6b",
  "sidewalk-defender": "#e59f43",
  "cosmo-cleaner": "#0d9488",
  "pinokun-stamps": "#e0608a",
};
const appAccent = (slug: string) => APP_ACCENT[slug] ?? "var(--accent-deep)";
const appTitle = new Map(apps.map((a) => [a.slug, a.data.title]));
---

<BaseLayout title="Y.M Apps — 小さなアイデアを、かたちに。">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker">Solo software studio by PINO</p>
        <h1>小さなアイデアを、<br />かたちに。</h1>
        <p class="hero-lede">
          Android アプリ、Chrome 拡張、Web ゲーム、LINE スタンプ。読書や野球、日々のちょっとした不便から生まれたプロダクトをまとめています。
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#works">作品を見る</a>
          <a class="btn" href="#contact">相談する</a>
        </div>
        <dl class="hero-stats" aria-label="サイト概要">
          <div><dt>{apps.length}</dt><dd>Products</dd></div>
          <div><dt>{writings.length}</dt><dd>Writings</dd></div>
          <div><dt>2026</dt><dd>Active</dd></div>
        </dl>
      </div>

      <div class="hero-poster-img" aria-label="Y.M Apps のポスター">
        <picture>
          <source
            type="image/webp"
            srcset={`/assets/hero/poster-560.webp 560w, /assets/hero/poster.webp 1120w`}
            sizes="(max-width: 520px) 92vw, 560px"
          />
          <img
            src="/assets/hero/poster-1120.png"
            alt="創意工夫 — PINO のものづくり。ぴのくんと道具たちのポスター"
            width="1120"
            height="1120"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </div>
    </div>
  </section>

  <hr class="retro-hr" />

  <section class="featured-section">
    <div class="container">
      <a class="featured-card" href={`/works/${featured.slug}`} data-world={featured.data.world} data-sheen>
        <img class="pino-friend featured-pino" src="/assets/pinokun/pinokun-wave.png" alt="ぴのくん" loading="lazy" decoding="async" />
        <div class="featured-copy">
          <p class="featured-label">Featured Project</p>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.tagline}</p>
          <div class="featured-tags">
            {featured.data.badges.map((b) => <span class="tag">{b}</span>)}
          </div>
          <span class="featured-link">詳しく見る →</span>
        </div>
        <div class="featured-media" aria-hidden="true">
          {featured.data.coverImage && (
            <img class="featured-cover" src={featured.data.coverImage} alt="" loading="lazy" decoding="async" />
          )}
          {featured.data.screenshots.filter((src) => src !== featured.data.coverImage).slice(0, 2).map((src, i) => (
            <img class={`featured-shot shot-${i + 1}`} src={src} alt="" loading="lazy" decoding="async" />
          ))}
        </div>
      </a>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== WORKS (simple list) ============== */}
  <section id="works" class="stack-section">
    <div class="container">
      <SectionHead
        title="Works"
        lede="ぜんぶ、自分がほしいなと思って作りました。"
      />

      <div class="works-card">
        {groupedApps.map((group) => (
          <div class="work-group">
            <div class="work-group-head">
              <h3 class="work-group-title">{group.label.title}</h3>
              <p class="work-group-lede">{group.label.lede}</p>
            </div>
            <ul class="works-list">
              {group.items.map((app) => {
                const gi = indexOf.get(app.slug) ?? 0;
                return (
                  <li data-reveal data-reveal-delay={Math.min(gi, 5)}>
                    <a class="work-row" href={`/works/${app.slug}`} style={`--row-accent:${appAccent(app.slug)}`}>
                      <span class="work-no">{String(gi + 1).padStart(2, "0")}</span>
                      <div class="work-body">
                        <div class="work-head">
                          <span class="work-title">{app.data.title}</span>
                          {app.data.isNew && <span class="work-new">NEW</span>}
                          {app.data.unpublished && <span class="work-pending">準備中</span>}
                          <span class="work-platform">{app.data.platform}</span>
                        </div>
                        <p class="work-tag">{app.data.tagline}</p>
                      </div>
                      <span class="work-more" aria-hidden="true">→</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== WRITINGS ============== */}
  <section id="writings" class="stack-section">
    <div class="container">
      <SectionHead
        title="Writings"
        lede="アプリ開発の裏側、E-Ink 端末の検証ログ、AI との付き合い方。note で公開しています。"
      />

      <div class="card">
        <ul class="ruled-list">
          {recentWritings.map((w, i) => (
            <li data-reveal data-reveal-delay={Math.min(i, 5)}>
              <span class="w-main">
                <a href={w.data.url} target="_blank" rel="noopener noreferrer">{w.data.title}</a>
                {w.data.relatedApp && appTitle.get(w.data.relatedApp) && (
                  <span class="w-app" style={`--c:${appAccent(w.data.relatedApp)}`}>{appTitle.get(w.data.relatedApp)}</span>
                )}
              </span>
              <span class="meta">{w.data.date.replace(/-/g, "/").slice(2)}</span>
            </li>
          ))}
        </ul>
      </div>

      <p style="margin-top:14px; text-align:right;">
        <a href="/writings" style="font-size:12px;font-weight:900;">すべての記事 ({writings.length}) →</a>
      </p>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== OMIKUJI (fun) ============== */}
  <Omikuji />

  <hr class="retro-hr" />

  {/* ============== ABOUT ============== */}
  <section id="about" class="stack-section">
    <div class="container">
      <SectionHead
        title="About"
      />

      <div class="about-card" data-sheen data-reveal>
        <span class="tape tape-tl" aria-hidden="true"></span>
        <div class="about-head">
          <img class="about-avatar" src="/assets/pinokun/pinokun-wave.png" alt="" loading="lazy" decoding="async" />
          <div class="about-id">
            <p class="about-name">PINO</p>
            <a class="about-handle" href="https://x.com/Pinopino503" target="_blank" rel="noopener noreferrer">@Pinopino503</a>
          </div>
        </div>
        <div class="about-body">
          <p>Android と Web を中心に、AI を相棒にアプリ・拡張機能・ゲーム・LINE スタンプを作っている個人開発者です。</p>
          <p>「使い続けられる」「無理なく続く」── そんな、静かに暮らしへ馴染むものを目指しています。</p>
        </div>
        <ul class="about-likes" aria-label="好きなもの">
          <li>📖 読書</li>
          <li>⚾ 野球</li>
          <li>☕ コーヒー</li>
          <li>🛠 小さな道具</li>
        </ul>
      </div>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== CONTACT (Press 統合) ============== */}
  <section id="contact" class="stack-section">
    <div class="container">
      <SectionHead
        title="Contact"
        lede="お仕事のご依頼、アプリへのご要望、バグ報告などは、メールでお気軽にどうぞ。"
      />

      <div class="contact-panel">
        <div class="contact-cta">
          {/* メーラーが設定されている環境：mailto: で送信画面が開く。
              未設定の環境：押下時にアドレスをクリップボードにコピー。
              メーラー未起動だった場合の保険として、800ms 後にヒント表示。

              ボット対策：HTML 上にはメアドの完全形を出さず、ローカル部と
              ドメイン部を data 属性に分割して保持。JS で組み立ててから
              href に流し込む。簡易スクレイパは @ 記号で正規表現マッチ
              するので、これだけで取れる確率はぐっと下がる。 */}
          <a
            id="contact-link"
            class="btn btn-primary"
            href="#contact"
            data-l="y.m_games503"
            data-d="protonmail.com"
          >
            <svg class="btn-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2zm-2 0-8 5-8-5zm0 12H4V8l8 5 8-5z"/></svg>
            メールを送る
          </a>
          <p id="copy-hint" class="copy-hint" hidden aria-live="polite">
            メーラーが開かない場合は、アドレスをクリップボードにコピー済みです。お使いのメールアプリに貼り付けてご連絡ください。
          </p>
        </div>

        <script>
          // mailto: + クリップボードコピーの合わせ技。
          // ボット対策：data-l / data-d を JS で組み立てて mailto: 化。
          //   メーラー設定済み → 既定アプリが起動。
          //   未設定 → ヒントとクリップボードで救済。
          const link = document.getElementById("contact-link") as HTMLAnchorElement | null;
          const hint = document.getElementById("copy-hint");
          if (link && hint) {
            const local = link.dataset.l ?? "";
            const domain = link.dataset.d ?? "";
            const email = `${local}@${domain}`;
            // ページ表示直後に href を mailto: に置き換える。
            // 右クリック「リンクをコピー」もこの時点で機能する。
            link.setAttribute("href", `mailto:${email}`);

            let hideId: number | undefined;
            link.addEventListener("click", () => {
              // クリップボードコピー（失敗してもメーラー起動は妨げない）
              navigator.clipboard.writeText(email).catch(() => {
                // 古いブラウザ用フォールバック
                const ta = document.createElement("textarea");
                ta.value = email;
                ta.style.position = "fixed";
                ta.style.opacity = "0";
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand("copy"); } catch {}
                document.body.removeChild(ta);
              });
              // メーラー起動の試行が落ち着いた頃にヒント表示
              window.setTimeout(() => {
                hint.hidden = false;
              }, 800);
              // 10 秒後に隠す
              if (hideId) window.clearTimeout(hideId);
              hideId = window.setTimeout(() => { hint.hidden = true; }, 10000);
            });
          }
        </script>

        <p class="contact-subhead">その他のリンク</p>

        <div class="social-grid">
          <a class="social-card" data-brand="x" href="https://x.com/Pinopino503" target="_blank" rel="noopener noreferrer" title="X (Twitter)" aria-label="X (Twitter) — @Pinopino503">
            <span class="social-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"/></svg></span>
            <span class="social-handle">@Pinopino503</span>
          </a>
          <a class="social-card" data-brand="note" href="https://note.com/y_m656" target="_blank" rel="noopener noreferrer" title="note" aria-label="note — @y_m656">
            <span class="social-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2zm4 2h10v2H7zm0 4h7v2H7z"/></svg></span>
            <span class="social-handle">@y_m656</span>
          </a>
          <a class="social-card" data-brand="itch" href="https://pinopino503.itch.io/" target="_blank" rel="noopener noreferrer" title="itch.io" aria-label="itch.io — pinopino503">
            <span class="social-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.13 1.338C2.08 1.96.02 4.328 0 4.95v1.03c0 1.303 1.22 2.45 2.325 2.45 1.33 0 2.436-1.102 2.436-2.41 0 1.308 1.07 2.41 2.4 2.41 1.328 0 2.362-1.102 2.362-2.41 0 1.308 1.137 2.41 2.466 2.41h.024c1.33 0 2.466-1.102 2.466-2.41 0 1.308 1.034 2.41 2.363 2.41 1.33 0 2.4-1.102 2.4-2.41 0 1.308 1.106 2.41 2.435 2.41C22.78 8.43 24 7.282 24 5.98V4.95c-.02-.62-2.082-2.99-3.13-3.612-3.253-.114-5.508-.134-8.87-.133-3.362 0-7.945.053-8.87.133zm6.376 6.477a2.74 2.74 0 0 1-.468.602c-.5.49-1.19.795-1.947.795a2.786 2.786 0 0 1-1.95-.795c-.182-.178-.32-.37-.446-.59-.127.222-.303.412-.486.59a2.788 2.788 0 0 1-1.95.795c-.092 0-.187-.025-.264-.052-.107 1.113-.152 2.176-.168 2.95v.005l-.006 1.167c.02 2.334-.23 7.564 1.03 8.85 1.952.454 5.545.662 9.15.663 3.605 0 7.198-.21 9.15-.664 1.26-1.284 1.01-6.514 1.03-8.848l-.006-1.167v-.004c-.016-.775-.06-1.838-.168-2.95-.077.026-.172.052-.263.052a2.788 2.788 0 0 1-1.95-.795c-.184-.178-.36-.368-.486-.59-.127.22-.265.412-.447.59a2.786 2.786 0 0 1-1.95.794c-.76 0-1.446-.303-1.948-.793a2.74 2.74 0 0 1-.468-.602 2.738 2.738 0 0 1-.463.602 2.787 2.787 0 0 1-1.95.794h-.16a2.787 2.787 0 0 1-1.95-.793 2.738 2.738 0 0 1-.464-.602zm-2.004 2.59v.002c.795.002 1.5 0 2.373.953.687-.072 1.406-.108 2.125-.107.72 0 1.438.035 2.125.107.873-.953 1.578-.95 2.372-.953.376 0 1.876 0 2.92 2.934l1.123 4.028c.832 2.995-.266 3.068-1.636 3.07-2.03-.075-3.156-1.55-3.156-3.025-1.124.184-2.436.276-3.748.277-1.312 0-2.624-.093-3.748-.277 0 1.475-1.125 2.95-3.156 3.026-1.37-.004-2.468-.077-1.636-3.072l1.122-4.027c1.045-2.934 2.545-2.934 2.92-2.934zM12 12.714c-.002.002-2.14 1.964-2.523 2.662l1.4-.056v1.22c0 .056.56.033 1.123.007.562.026 1.124.05 1.124-.008v-1.22l1.4.055C14.138 14.677 12 12.713 12 12.713z"/></svg></span>
            <span class="social-handle">pinopino503</span>
          </a>
          <a class="social-card" data-brand="line" href="https://store.line.me/stickershop/author/1039160/ja" target="_blank" rel="noopener noreferrer" title="LINE STORE" aria-label="LINE STORE — クリエイターページ">
            <span class="social-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg></span>
            <span class="social-handle">クリエイターページ</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 52px 0 34px;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 24px 0 auto 0;
    height: 420px;
    background:
      radial-gradient(circle at 78% 26%, rgba(255, 216, 77, 0.26), transparent 30%),
      radial-gradient(circle at 22% 48%, rgba(61, 125, 142, 0.18), transparent 34%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.03fr) minmax(280px, 0.78fr);
    align-items: center;
    gap: 44px;
  }
  .hero-copy {
    max-width: 620px;
  }
  .hero-kicker {
    display: inline-flex;
    margin-bottom: 14px;
    color: var(--accent-deep);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-copy h1 {
    font-size: clamp(34px, 5.6vw, 64px);
    line-height: 1.14;
    letter-spacing: 0.01em;
    max-width: 720px;
    text-wrap: balance;
    word-break: keep-all;       /* don't split runs mid-word */
    line-break: strict;         /* kinsoku: 「、。」 never start a line */
    overflow-wrap: normal;      /* (was: anywhere — it forced 「、」 to the line head) */
  }
  .hero-copy h1 br { display: inline; }
  .hero-lede {
    max-width: 560px;
    margin-top: 20px;
    color: var(--muted);
    font-size: 15.5px;
    line-height: 2;
  }
  .hero-poster-img {
    position: relative;
    text-align: center;
  }
  .hero-poster-img::before {
    content: "";
    position: absolute;
    inset: 8% -12% -8% 12%;
    background: var(--accent);
    border-radius: 36px;
    transform: rotate(5deg);
    opacity: 0.18;
    z-index: -1;
  }
  .hero-poster-img img {
    display: block;
    width: 100%;
    max-width: 430px;
    height: auto;
    margin: 0 auto;
    border-radius: 18px;
    border: 1px solid rgba(52, 64, 84, 0.12);
    box-shadow: 0 26px 70px -38px rgba(38, 52, 74, 0.55);
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 26px;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    max-width: 430px;
    margin-top: 30px;
  }
  .hero-stats div {
    padding: 14px 0 0;
    border-top: 1px solid var(--line-strong);
  }
  .hero-stats dt {
    color: var(--brown-1);
    font-size: 22px;
    font-weight: 900;
    line-height: 1;
  }
  .hero-stats dd {
    margin-top: 6px;
    color: var(--muted);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured-section {
    padding: 22px 0 4px;
  }
  .featured-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: 30px;
    align-items: center;
    min-height: 360px;
    padding: 34px;
    color: var(--ink);
    text-decoration: none;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.24), transparent 42%),
