  .feat-phone.b{ right:0; bottom:94px; transform:rotate(7deg); z-index:1; width:152px; }
  .feat-cat{ position:absolute; right:212px; bottom:14px; width:120px; z-index:3; }

  .feat-side{ background:linear-gradient(160deg,#312b25,#211c18); color:#f3ece0; padding:26px 24px; display:flex; flex-direction:column; position:relative; }
  .feat-side .badge-new{ position:absolute; top:18px; left:20px; z-index:3; }
  .feat-shot{ border-radius:12px; overflow:hidden; border:1px solid rgba(255,255,255,.12); box-shadow:0 10px 30px -10px rgba(0,0,0,.6); aspect-ratio:16/10; background:#0a0d12; margin-bottom:16px; }
  .feat-shot img{ width:100%; height:100%; object-fit:cover; image-rendering:pixelated; }
