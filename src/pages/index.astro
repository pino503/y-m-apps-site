---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps")).sort((a, b) => a.data.order - b.data.order);

const lead = apps.find((a) => a.slug === "inkpress") ?? apps[0];
const cosmo = apps.find((a) => a.slug === "cosmo-cleaner") ?? apps[apps.length - 1];

// Works grouped by category — design order TOOLS → GAMES → STICKERS.
const CAT_ORDER = ["tool", "game", "sticker"] as const;
const CAT_META: Record<(typeof CAT_ORDER)[number], { title: string; lede: string; icon: string }> = {
  tool: {
    title: "TOOLS",
    lede: "ちょっと便利な道具",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a4 4 0 00-5.4 5.4l-6 6 2 2 6-6a4 4 0 005.4-5.4l-2.3 2.3-1.7-.3-.3-1.7 2.3-2.3z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>`,
  },
  game: {
    title: "GAMES",
    lede: "小さく遊べる実験",
    icon: `<svg viewBox="0 0 24 24" fill="none"><rect x="2.5" y="7" width="19" height="10" rx="5" stroke="currentColor" stroke-width="1.7"/><path d="M7 10v4M5 12h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="16" cy="11" r="1.1" fill="currentColor"/><circle cx="18.5" cy="13.5" r="1.1" fill="currentColor"/></svg>`,
  },
  sticker: {
    title: "STICKERS",
    lede: "会話に使えるゆるいもの",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M4 9l1.5-4L9 7M20 9l-1.5-4L15 7" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M5 10c0-2 3-3 7-3s7 1 7 3c0 5-3 9-7 9s-7-4-7-9z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><circle cx="9.5" cy="12" r="1" fill="currentColor"/><circle cx="14.5" cy="12" r="1" fill="currentColor"/></svg>`,
  },
};
const groups = CAT_ORDER.map((cat) => ({
  cat,
  meta: CAT_META[cat],
  items: apps.filter((a) => a.data.category === cat),
})).filter((g) => g.items.length > 0);

const writings = (await getCollection("writings")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const recentWritings = writings.slice(0, 5);
const appTitle = new Map(apps.map((a) => [a.slug, a.data.title]));

const arrow = `<svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<BaseLayout title="Y.M Apps — 小さなアイデアを、かたちに。">

  {/* ============ HERO ============ */}
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="reveal">
        <p class="eyebrow">Solo software studio by PINO</p>
        <h1>
          <svg class="spark" viewBox="0 0 48 48" fill="none"><path d="M24 4v12M24 32v12M4 24h12M32 24h12" stroke="#f4b73e" stroke-width="3.4" stroke-linecap="round"/><path d="M10 10l7 7M31 31l7 7M38 10l-7 7M17 31l-7 7" stroke="#f4b73e" stroke-width="3" stroke-linecap="round" opacity=".7"/></svg>
          小さなアイデアを、<br />かたちに。
        </h1>
        <p class="lead">Androidアプリ、Webゲーム、Chrome拡張、LINEスタンプなど、日々の小さな「ほしい」を形にしている個人開発スタジオです。便利さと遊び心のあいだにある、ちょうどいいものを作っています。</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="#works">
            <svg viewBox="0 0 24 24" fill="none"><path d="M3 7l9-4 9 4-9 4-9-4zM3 7v10l9 4M21 7v10l-9 4" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            作ったものを見る
          </a>
          <a class="btn btn-outline" href="#contact">
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 5h16v12H8l-4 4V5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            制作について相談する
          </a>
        </div>
        <div class="stats">
          <div class="stat"><div class="num">{apps.length}</div><div class="lbl">Products</div></div>
          <div class="stat"><div class="num">{writings.length}</div><div class="lbl">Writings</div></div>
          <div class="stat"><div class="num">2026</div><div class="lbl">Active</div></div>
        </div>
      </div>

      <div class="poster-stack reveal">
        <span class="paper p1"></span>
        <span class="paper p2"></span>
        <div class="poster">
          <span class="tape"></span>
          <picture>
            <source type="image/webp" srcset="/assets/hero/poster-560.webp 560w, /assets/hero/poster.webp 1120w" sizes="(max-width: 520px) 92vw, 520px" />
            <img src="/assets/hero/poster-1120.png" alt="創意工夫 — ぴのくんと道具たちのポスター" width="1120" height="1120" loading="eager" decoding="async" fetchpriority="high" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  {/* ============ FEATURED ============ */}
  <section class="section featured" style="padding-top:20px">
    <div class="wrap">
      <div class="card featured-card reveal">
        <div class="feat-main">
          <span class="feat-label">Featured Project</span>
          <h3>{lead.data.title}</h3>
          <p>E-Ink端末でも読みやすく、読書に集中できるシンプルな自炊本リーダー。</p>
          <div class="feat-chips">
            <span class="chip">Android</span>
            <span class="chip">v1.1.7</span>
            <span class="chip chip-gold">BOOX対応</span>
          </div>
          <a class="feat-more" href={`/works/${lead.slug}`}>InkPressを詳しく見る
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <div class="feat-visual">
            <img class="feat-phone a" src="/assets/apps/inkpress-onboarding.png" alt="" loading="lazy" />
            <img class="feat-phone b" src="/assets/apps/inkpress-settings.png" alt="" loading="lazy" />
            <img class="feat-cat" src="/assets/pinokun/pinokun-reading-color.png" alt="" loading="lazy" />
          </div>
        </div>
        <div class="feat-side">
          <span class="badge-new">NEW</span>
          <div class="feat-shot"><img src={cosmo.data.coverImage} alt={`${cosmo.data.title} のゲーム画面`} loading="lazy" /></div>
          <h4>{cosmo.data.title}</h4>
          <p>宇宙ゴミを集めて、基地で強化。掃除とシューティングを組み合わせた、CRT風の宇宙清掃ミニゲーム。</p>
          <a class="feat-more" href={`/works/${cosmo.slug}`}>詳しく見る
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ============ WORKS ============ */}
  <section class="section" id="works">
    <div class="wrap">
      <div class="sec-head reveal">
        <h2 class="sec-title">Works</h2>
        <p class="sec-sub">ぜんぶ、自分がほしいなと思って作りました。</p>
      </div>
      <div class="card works-card reveal">
        {groups.map((group) => (
          <div class="work-group">
            <div class="cat">
              <span class="cat-ico" set:html={group.meta.icon} />
              <div><h3>{group.meta.title}</h3><p>{group.meta.lede}</p></div>
            </div>
            <div class="app-rows">
              {group.items.map((app) => (
                <a class="app-row" href={`/works/${app.slug}`}>
                  <span class="app-ico">
                    {app.data.iconImage
                      ? <img src={app.data.iconImage} alt="" loading="lazy" />
                      : <span class="app-ic-mono">{app.data.title.slice(0, 1)}</span>}
                  </span>
                  <span class="app-name">{app.data.title}</span>
                  <span class="app-mid">
                    <span class="app-tags">
                      {app.data.isNew && <span class="badge-new">NEW</span>}
                      {app.data.badges.slice(0, 2).map((b) => <span class="chip">{b}</span>)}
                    </span>
                    <span class="app-desc">{app.data.tagline}</span>
                  </span>
                  <span class="app-arrow" set:html={arrow} />
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ WRITINGS ============ */}
  <section class="section" id="writings">
    <div class="wrap">
      <div class="sec-head reveal">
        <h2 class="sec-title">Writings</h2>
        <p class="sec-sub">アプリ開発の裏側、E-Ink端末の検証ログ、AIとの付き合い方。noteで公開しています。</p>
      </div>
      <div class="card writings-card reveal">
        {recentWritings.map((w) => (
          <a class="write-row" href={w.data.url} target="_blank" rel="noopener noreferrer">
            <span class="write-date">{w.data.date.replace(/-/g, "/")}</span>
            <span class="write-title">{w.data.title}</span>
            <span class="write-app">
              {w.data.relatedApp && appTitle.get(w.data.relatedApp)
                ? <span class="chip chip-gold">{appTitle.get(w.data.relatedApp)}</span>
                : <span class="chip">開発のこと</span>}
            </span>
            <span class="write-go">読む<svg viewBox="0 0 24 24" width="14" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>
        ))}
        <div class="writings-foot">
          <a class="link-more" href="/writings">すべての記事 ({writings.length})
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ============ OMIKUJI ============ */}
  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="card omikuji reveal">
        <span class="washi"></span>
        <img class="omi-cat" src="/assets/pinokun/pinokun-reading-color.png" alt="" loading="lazy" />
        <div class="omi-body">
          <span class="tag">Fun · おまけ</span>
          <h3>ぴのくんおみくじ</h3>
          <p>今日の運勢を、ぴのくんが占います。1日のはじまりに、軽い気持ちでどうぞ。</p>
        </div>
        <div class="omi-action">
          <button class="btn btn-primary" data-omikuji>
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 3c2 3 5 4 5 8a5 5 0 01-10 0c0-4 3-5 5-8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            おみくじを引く
          </button>
          <div class="omi-result" data-omikuji-result><span class="omi-msg">ボタンを押してね</span></div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ ABOUT ============ */}
  <section class="section" id="about">
    <div class="wrap">
      <div class="sec-head reveal"><h2 class="sec-title">About</h2></div>
      <div class="card about-card reveal">
        <div class="avatar"><img src="/assets/pinokun/pinokun-profile.png" alt="PINO" /></div>
        <div class="about-body">
          <div class="who"><h3>PINO</h3><a class="handle" href="https://x.com/Pinopino503" target="_blank" rel="noopener noreferrer">@Pinopino503</a></div>
          <p>Android と Web を中心に、AI を相棒にアプリ・拡張機能・ゲーム・LINEスタンプを作っている個人開発者です。「使い続けられる」「無理なく続く」── そんな、静かに暮らしへ馴染むものを目指しています。</p>
          <div class="skill-chips">
            <span class="skill"><svg viewBox="0 0 24 24" fill="none"><path d="M9 8l-4 4 4 4M15 8l4 4-4 4" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>開発</span>
            <span class="skill"><svg viewBox="0 0 24 24" fill="none"><path d="M4 20l4-1L19 8l-3-3L5 16l-1 4z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>デザイン</span>
            <span class="skill"><svg viewBox="0 0 24 24" fill="none"><rect x="2.5" y="7" width="19" height="10" rx="5" stroke="currentColor" stroke-width="1.7"/><path d="M7 10v4M5 12h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="16.5" cy="11.5" r="1" fill="currentColor"/><circle cx="18" cy="13.5" r="1" fill="currentColor"/></svg>ゲーム</span>
            <span class="skill"><svg viewBox="0 0 24 24" fill="none"><path d="M12 20s-7-4.3-7-9a4 4 0 017-2.6A4 4 0 0119 11c0 4.7-7 9-7 9z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>ゆるい遊び心</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ CONTACT ============ */}
  <section class="section" id="contact">
    <div class="wrap">
      <div class="contact-top reveal">
        <div class="sec-head" style="margin:0">
          <h2 class="sec-title">Contact</h2>
          <p class="sec-sub">アプリ制作、Webページ、ゲーム制作、記事やデザインまわりのご相談など、まだ形になっていない段階でもお気軽にご連絡ください。</p>
        </div>
        {/* ボット対策：HTML 上にメアドの完全形を出さず、ローカル部とドメイン部を data 属性に分割。JS で mailto: を組み立てる。 */}
        <a id="contact-link" class="btn btn-primary" href="#contact" data-l="y.m_games503" data-d="protonmail.com">
          <svg viewBox="0 0 24 24" fill="none"><path d="M3 6h18v12H3z" stroke="currentColor" stroke-width="1.8"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
          メールで相談する
        </a>
      </div>
      <p id="copy-hint" class="copy-hint" hidden aria-live="polite">
        メーラーが開かない場合は、アドレスをクリップボードにコピー済みです。お使いのメールアプリに貼り付けてご連絡ください。
      </p>
      <div class="socials reveal">
        <a class="social" href="https://x.com/Pinopino503" target="_blank" rel="noopener noreferrer">
          <span class="social-ico ico-x"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.2 3h3.3l-7.2 8.2L23 21h-6.6l-5.2-6.8L5.3 21H2l7.7-8.8L1.5 3h6.8l4.7 6.2L18.2 3zm-1.2 16h1.8L7.1 5H5.2L17 19z"/></svg></span>
          <span class="meta"><b>@Pinopino503</b><span>X (Twitter)</span></span>
        </a>
        <a class="social" href="https://note.com/y_m656" target="_blank" rel="noopener noreferrer">
          <span class="social-ico ico-note"><svg viewBox="0 0 24 24" fill="none"><path d="M3 7v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2z" stroke="#fff" stroke-width="1.7"/><path d="M7 9h10M7 13h7" stroke="#fff" stroke-width="1.7" stroke-linecap="round"/></svg></span>
          <span class="meta"><b>@y_m656</b><span>note</span></span>
        </a>
        <a class="social" href="https://pinopino503.itch.io/" target="_blank" rel="noopener noreferrer">
          <span class="social-ico ico-itch"><svg viewBox="0 0 24 24" fill="none"><path d="M4 6h16l1 5-4 3-3-2-2 2-2-2-3 2-4-3 1-5z" stroke="#fff" stroke-width="1.6" stroke-linejoin="round"/><path d="M5 11v6a2 2 0 002 2h10a2 2 0 002-2v-6" stroke="#fff" stroke-width="1.6"/></svg></span>
          <span class="meta"><b>pinopino503</b><span>itch.io</span></span>
        </a>
        <a class="social" href="https://store.line.me/stickershop/author/1039160/ja" target="_blank" rel="noopener noreferrer">
          <span class="social-ico ico-line"><svg viewBox="0 0 24 24" fill="none"><path d="M12 4c4.4 0 8 2.9 8 6.4 0 3.6-3.6 6.5-8 6.5-.7 0-1.4-.1-2-.2L6 19l.6-2.8C4.9 15 4 12.9 4 10.4 4 6.9 7.6 4 12 4z" stroke="#fff" stroke-width="1.7" stroke-linejoin="round"/></svg></span>
          <span class="meta"><b>クリエイターページ</b><span>LINE STORE</span></span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // --- Contact: mailto + クリップボードコピー（ボット対策で JS 組み立て）---
  function initContact() {
    const link = document.getElementById("contact-link") as HTMLAnchorElement | null;
    const hint = document.getElementById("copy-hint");
    if (!link || !hint || (link as any)._bound) return;
    (link as any)._bound = true;
    const email = `${link.dataset.l ?? ""}@${link.dataset.d ?? ""}`;
    link.setAttribute("href", `mailto:${email}`);
    let hideId: number | undefined;
    link.addEventListener("click", () => {
      navigator.clipboard?.writeText(email).catch(() => {});
      window.setTimeout(() => { hint.hidden = false; }, 800);
      if (hideId) window.clearTimeout(hideId);
      hideId = window.setTimeout(() => { hint.hidden = true; }, 10000);
    });
  }

  // --- Omikuji ---
  function initOmikuji() {
    const btn = document.querySelector("[data-omikuji]") as HTMLElement | null;
    if (!btn || (btn as any)._bound) return;
    (btn as any)._bound = true;
    const out = document.querySelector("[data-omikuji-result]");
    const fortunes = [
      { r: "大吉", c: "いいことが続きそう。新しい一歩を踏み出すのにぴったりの日。", good: 2 },
      { r: "中吉", c: "ゆっくり進めば大丈夫。コーヒー片手にどうぞ。", good: 1 },
      { r: "小吉", c: "小さな発見がある一日。メモを忘れずに。", good: 1 },
      { r: "吉", c: "いつも通りが、いちばん強い。マイペースでいこう。", good: 0 },
      { r: "末吉", c: "あせらず、ひと休み。野球でも観て深呼吸。", good: 0 },
      { r: "吉", c: "誰かのひとことが、ヒントになるかも。", good: 0 },
    ];
    btn.addEventListener("click", () => {
      const f = fortunes[Math.floor(Math.random() * fortunes.length)];
      if (out) {
        out.innerHTML = `<span class="omi-rank">${f.r}</span><span class="omi-msg">${f.c}</span>`;
        out.classList.remove("pop"); void (out as HTMLElement).offsetWidth; out.classList.add("pop");
      }
      (window as any).ymSfx?.chime?.(f.good);
    });
  }

  function initHome() { initContact(); initOmikuji(); }
  document.addEventListener("astro:page-load", initHome);
  if (document.readyState !== "loading") initHome();
  else document.addEventListener("DOMContentLoaded", initHome);
</script>

<style>
  /* ============ HERO ============ */
  .hero{ padding:56px 0 24px; }
  .hero-grid{ display:grid; grid-template-columns:1.04fr .96fr; gap:48px; align-items:center; }
  .eyebrow{ font-family:var(--font-body); font-weight:700; font-size:12px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold-deep); margin:0 0 18px; }
  .hero h1{ font-family:var(--font-display); font-weight:900; color:var(--ink); font-size:clamp(34px,4.7vw,54px); line-height:1.18; letter-spacing:.005em; margin:0 0 22px; position:relative; word-break:keep-all; line-break:strict; overflow-wrap:normal; }
  .hero h1 br{ display:inline; }
  .hero h1 .spark{ position:absolute; top:-26px; left:-30px; width:46px; height:46px; }
  .hero p.lead{ font-size:16.5px; color:var(--ink-2); max-width:48ch; margin:0 0 30px; line-height:1.9; }
  .hero-cta{ display:flex; gap:14px; flex-wrap:wrap; margin-bottom:40px; }
  .stats{ display:flex; gap:42px; }
  .stat .num{ font-family:var(--font-display); font-weight:900; font-size:34px; line-height:1; color:var(--ink); }
  .stat .lbl{ font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:var(--ink-3); font-weight:600; margin-top:6px; }

  .poster-stack{ position:relative; }
  .poster-stack .paper{ position:absolute; inset:0; border-radius:26px; }
  .poster-stack .p1{ background:var(--gold-soft); transform:rotate(-4.5deg) translate(14px,16px); box-shadow:var(--sh-2); }
  .poster-stack .p2{ background:#fce9bf; transform:rotate(3deg) translate(-10px,8px); box-shadow:var(--sh-1); }
  .poster{ position:relative; border-radius:26px; overflow:hidden; box-shadow:var(--sh-3); border:5px solid var(--paper); background:var(--paper); }
  /* height:auto so the img's width/height attrs (kept for CLS) don't override aspect-ratio → keeps the square poster from being cropped tall */
  .poster img{ width:100%; height:auto; aspect-ratio:1/1; object-fit:cover; display:block; }
  .poster .tape{ position:absolute; top:-10px; left:50%; transform:translateX(-50%) rotate(-2deg); width:96px; height:24px; background:rgba(244,183,62,.55); border:1px dashed rgba(226,150,42,.6); border-radius:2px; z-index:2; }

  /* ============ FEATURED ============ */
  .featured{ padding-top:18px; }
  .featured-card{ display:grid; grid-template-columns:1.62fr 1fr; gap:0; overflow:hidden; padding:0; }
  .feat-main{ padding:38px 36px; position:relative; display:flex; flex-direction:column; min-height:340px; }
  .feat-label{ font-size:11.5px; letter-spacing:.18em; font-weight:700; text-transform:uppercase; color:var(--gold-deep); }
  .feat-main h3{ font-family:var(--font-display); font-weight:900; font-size:40px; margin:8px 0 12px; color:var(--ink); }
