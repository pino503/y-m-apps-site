  .omi-seal{ width:98px; height:auto; display:block; filter:drop-shadow(0 5px 10px rgba(120,40,24,.28)); }
  .omi-slip.show .omi-seal{ animation:omiSealIn .6s cubic-bezier(.22,1.2,.4,1) both; }
  @keyframes omiSealIn{ 0%{ transform:scale(.4) rotate(-14deg); opacity:0 } 60%{ transform:scale(1.08) rotate(3deg); opacity:1 } 100%{ transform:none } }
