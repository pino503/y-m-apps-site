---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import Slot from "../components/Slot.astro";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps")).sort(
  (a, b) => a.data.order - b.data.order
);

const writings = (await getCollection("writings")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const recentWritings = writings.slice(0, 5);
const featured = apps.find((app) => app.slug === "inkpress") ?? apps[0];
---

<BaseLayout title="Y.M Apps — 暮らしに溶ける、小さな道具">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker">Solo software studio by PINO</p>
        <h1>暮らしに溶ける、小さな道具をつくっています。</h1>
        <p class="hero-lede">
          Android アプリ、Chrome 拡張、Web ゲーム、LINE スタンプ。読書や野球、日々のちょっとした不便から生まれたプロダクトをまとめています。
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#works">作品を見る</a>
          <a class="btn" href="#contact">相談する</a>
        </div>
        <dl class="hero-stats" aria-label="サイト概要">
          <div><dt>6</dt><dd>Products</dd></div>
          <div><dt>15</dt><dd>Writings</dd></div>
          <div><dt>2026</dt><dd>Active</dd></div>
        </dl>
      </div>

      <div class="hero-poster-img" aria-label="Y.M Apps のポスター">
        <picture>
          <source
            type="image/webp"
            srcset={`/assets/hero/poster-560.webp 560w, /assets/hero/poster.webp 1120w`}
            sizes="(max-width: 520px) 92vw, 560px"
          />
          <img
            src="/assets/hero/poster-1120.png"
            alt="創意工夫 — PINO のものづくり。ぴのくんと道具たちのポスター"
            width="1120"
            height="1120"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </div>
    </div>
  </section>

  <hr class="retro-hr" />

  <section class="featured-section">
    <div class="container">
      <a class="featured-card" href={`/works/${featured.slug}`} data-world={featured.data.world}>
        <img class="pino-friend featured-pino" src="/assets/pinokun/pinokun-wave.png" alt="ぴのくん" loading="lazy" decoding="async" />
        <div class="featured-copy">
          <p class="featured-label">Featured Project</p>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.tagline}</p>
          <div class="featured-tags">
            {featured.data.badges.map((b) => <span class="tag">{b}</span>)}
          </div>
          <span class="featured-link">詳しく見る →</span>
        </div>
        <div class="featured-media" aria-hidden="true">
          {featured.data.coverImage && (
            <img class="featured-cover" src={featured.data.coverImage} alt="" loading="lazy" decoding="async" />
          )}
          {featured.data.screenshots.filter((src) => src !== featured.data.coverImage).slice(0, 2).map((src, i) => (
            <img class={`featured-shot shot-${i + 1}`} src={src} alt="" loading="lazy" decoding="async" />
          ))}
        </div>
      </a>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== WORKS (simple list) ============== */}
  <section id="works" class="stack-section">
    <div class="container">
      <SectionHead
        title="Works"
        lede="ぜんぶ、自分がほしいなと思って作りました。"
      />

      <div class="works-card">
        <ul class="works-list">
          {apps.map((app, i) => (
            <li data-reveal data-reveal-delay={Math.min(i, 5)}>
              <a class="work-row" href={`/works/${app.slug}`}>
                <span class="work-no">{String(i + 1).padStart(2, "0")}</span>
                <div class="work-body">
                  <div class="work-head">
                    <span class="work-title">{app.data.title}</span>
                    <span class="work-platform">{app.data.platform}</span>
                  </div>
                  <p class="work-tag">{app.data.tagline}</p>
                </div>
                <span class="work-more" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== WRITINGS ============== */}
  <section id="writings" class="stack-section">
    <div class="container">
      <SectionHead
        title="Writings"
        lede="アプリ開発の裏側、E-Ink 端末の検証ログ、AI との付き合い方。note で公開しています。"
      />

      <div class="card">
        <ul class="ruled-list">
          {recentWritings.map((w, i) => (
            <li data-reveal data-reveal-delay={Math.min(i, 5)}>
              <a href={w.data.url} target="_blank" rel="noopener noreferrer">{w.data.title}</a>
              <span class="meta">{w.data.date.replace(/-/g, "/").slice(2)}</span>
            </li>
          ))}
        </ul>
      </div>

      <p style="margin-top:14px; text-align:right;">
        <a href="/writings" style="font-size:12px;font-weight:900;">すべての記事 ({writings.length}) →</a>
      </p>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== ABOUT ============== */}
  <section id="about" class="stack-section">
    <div class="container">
      <SectionHead
        title="About"
      />

      <div class="about-panel">
        <div class="about-body">
          <p><strong>PINO</strong>（<a href="https://x.com/Pinopino503" target="_blank" rel="noopener noreferrer">@Pinopino503</a>）。Android と Web を中心に、AI を相棒にアプリ・拡張機能・ゲーム・LINE スタンプを作っている個人開発者です。</p>
          <p>読書、野球、生活を整える小さな道具が好き。「使い続けられる」「無理なく続く」── そんな静かに馴染むものを目指しています。</p>
          <p>お仕事のご依頼、アプリへのご要望、バグ報告などは <a href="#contact">Contact</a> からどうぞ。</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="retro-hr" />

  {/* ============== CONTACT (Press 統合) ============== */}
  <section id="contact" class="stack-section">
    <div class="container">
      <SectionHead
        title="Contact"
        lede="お仕事のご依頼、アプリへのご要望、バグ報告などは、メールでお気軽にどうぞ。"
      />

      <div class="contact-panel">
        <div class="contact-cta">
          {/* メーラーが設定されている環境：mailto: で送信画面が開く。
              未設定の環境：押下時にアドレスをクリップボードにコピー。
              メーラー未起動だった場合の保険として、800ms 後にヒント表示。

              ボット対策：HTML 上にはメアドの完全形を出さず、ローカル部と
              ドメイン部を data 属性に分割して保持。JS で組み立ててから
              href に流し込む。簡易スクレイパは @ 記号で正規表現マッチ
              するので、これだけで取れる確率はぐっと下がる。 */}
          <a
            id="contact-link"
            class="btn btn-primary"
            href="#contact"
            data-l="y.m_games503"
            data-d="protonmail.com"
          >
            ✉ メールを送る
          </a>
          <p id="copy-hint" class="copy-hint" hidden aria-live="polite">
            メーラーが開かない場合は、アドレスをクリップボードにコピー済みです。お使いのメールアプリに貼り付けてご連絡ください。
          </p>
        </div>

        <script>
          // mailto: + クリップボードコピーの合わせ技。
          // ボット対策：data-l / data-d を JS で組み立てて mailto: 化。
          //   メーラー設定済み → 既定アプリが起動。
          //   未設定 → ヒントとクリップボードで救済。
          const link = document.getElementById("contact-link") as HTMLAnchorElement | null;
          const hint = document.getElementById("copy-hint");
          if (link && hint) {
            const local = link.dataset.l ?? "";
            const domain = link.dataset.d ?? "";
            const email = `${local}@${domain}`;
            // ページ表示直後に href を mailto: に置き換える。
            // 右クリック「リンクをコピー」もこの時点で機能する。
            link.setAttribute("href", `mailto:${email}`);

            let hideId: number | undefined;
            link.addEventListener("click", () => {
              // クリップボードコピー（失敗してもメーラー起動は妨げない）
              navigator.clipboard.writeText(email).catch(() => {
                // 古いブラウザ用フォールバック
                const ta = document.createElement("textarea");
                ta.value = email;
                ta.style.position = "fixed";
                ta.style.opacity = "0";
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand("copy"); } catch {}
                document.body.removeChild(ta);
              });
              // メーラー起動の試行が落ち着いた頃にヒント表示
              window.setTimeout(() => {
                hint.hidden = false;
              }, 800);
              // 10 秒後に隠す
              if (hideId) window.clearTimeout(hideId);
              hideId = window.setTimeout(() => { hint.hidden = true; }, 10000);
            });
          }
        </script>

        <p class="contact-subhead">その他のリンク</p>

        <ul class="contact-list">
          <li><span class="k">X</span><a href="https://x.com/Pinopino503" target="_blank" rel="noopener noreferrer">@Pinopino503</a></li>
          <li><span class="k">note</span><a href="https://note.com/y_m656" target="_blank" rel="noopener noreferrer">@y_m656</a></li>
          <li><span class="k">itch.io</span><a href="https://pinopino503.itch.io/" target="_blank" rel="noopener noreferrer">pinopino503</a></li>
          <li><span class="k">LINE STORE</span><a href="https://store.line.me/stickershop/author/1039160/ja" target="_blank" rel="noopener noreferrer">クリエイターページ</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 52px 0 34px;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 24px 0 auto 0;
    height: 420px;
    background:
      radial-gradient(circle at 78% 26%, rgba(255, 216, 77, 0.26), transparent 30%),
      radial-gradient(circle at 22% 48%, rgba(61, 125, 142, 0.18), transparent 34%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.03fr) minmax(280px, 0.78fr);
    align-items: center;
    gap: 44px;
  }
  .hero-copy {
    max-width: 620px;
  }
  .hero-kicker {
    display: inline-flex;
    margin-bottom: 14px;
    color: var(--accent-deep);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-copy h1 {
    font-size: clamp(36px, 6vw, 68px);
    line-height: 1.08;
    letter-spacing: 0;
    max-width: 720px;
    text-wrap: balance;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }
  .hero-lede {
    max-width: 560px;
    margin-top: 20px;
    color: var(--muted);
    font-size: 15.5px;
    line-height: 2;
  }
  .hero-poster-img {
    position: relative;
    text-align: center;
  }
  .hero-poster-img::before {
    content: "";
    position: absolute;
    inset: 8% -12% -8% 12%;
    background: var(--accent);
    border-radius: 36px;
    transform: rotate(5deg);
    opacity: 0.18;
    z-index: -1;
  }
  .hero-poster-img img {
    display: block;
    width: 100%;
    max-width: 430px;
    height: auto;
    margin: 0 auto;
    border-radius: 18px;
    border: 1px solid rgba(52, 64, 84, 0.12);
    box-shadow: 0 26px 70px -38px rgba(38, 52, 74, 0.55);
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 26px;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    max-width: 430px;
    margin-top: 30px;
  }
  .hero-stats div {
    padding: 14px 0 0;
    border-top: 1px solid var(--line-strong);
  }
  .hero-stats dt {
    color: var(--brown-1);
    font-size: 22px;
    font-weight: 900;
    line-height: 1;
  }
  .hero-stats dd {
    margin-top: 6px;
    color: var(--muted);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured-section {
    padding: 22px 0 4px;
  }
  .featured-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: 30px;
    align-items: center;
    min-height: 360px;
    padding: 34px;
    color: var(--ink);
    text-decoration: none;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.24), transparent 42%),
      var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 26px 70px -52px rgba(38, 52, 74, 0.55);
  }
  .pino-friend {
    width: 82px;
    height: auto;
    display: block;
    filter: drop-shadow(0 10px 18px rgba(92, 73, 49, 0.14));
    pointer-events: none;
  }
  .featured-pino {
    position: absolute;
    right: 18px;
    top: 16px;
    z-index: 4;
    opacity: 0.92;
  }
  .featured-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    opacity: 1;
  }
  .featured-label {
    color: var(--accent-deep);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .featured-copy h2 {
    color: var(--ink);
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.08;
    letter-spacing: 0;
    margin-bottom: 14px;
  }
  .featured-copy p:not(.featured-label) {
    color: var(--muted);
    max-width: 420px;
    font-size: 15px;
    line-height: 1.9;
  }
  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin: 18px 0 20px;
  }
  .featured-link {
    color: var(--ink);
    font-size: 13px;
    font-weight: 900;
  }
  .featured-media {
    min-height: 360px;
    position: relative;
  }
  .featured-cover,
  .featured-shot {
    position: absolute;
    width: min(76%, 430px);
    max-height: 330px;
    object-fit: contain;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: 0 24px 50px -30px rgba(15, 23, 42, 0.74);
  }
  .featured-cover {
    right: 8%;
    top: 4%;
    z-index: 2;
  }
  .featured-shot {
    width: min(42%, 220px);
    z-index: 3;
  }
  .featured-shot.shot-1 {
    left: 0;
    bottom: 2%;
    transform: rotate(-4deg);
  }
  .featured-shot.shot-2 {
    right: 0;
    bottom: -2%;
    transform: rotate(4deg);
  }

  .works-card {
    margin-top: 16px;
    border-top: 1px solid var(--line-strong);
  }
  .works-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .works-list li + li {
    border-top: 1px solid var(--line);
  }
  .work-row {
    display: grid;
    grid-template-columns: 52px 1fr 30px;
    align-items: center;
    gap: 18px;
    padding: 22px 0;
    color: var(--brown-1);
    text-decoration: none;
    transition: opacity 0.2s var(--ease-out-cubic), transform 0.2s var(--ease-out-cubic);
  }
  .work-row:hover {
    opacity: 1;
    transform: translateX(4px);
    text-decoration: none;
  }
  .work-row:hover .work-more { color: var(--accent-deep); transform: translateX(3px); }
  .work-no {
    font-size: 12px;
    font-weight: 900;
    color: var(--accent-deep);
    letter-spacing: 0.08em;
  }
  .work-body { min-width: 0; }
  .work-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 4px;
  }
  .work-title {
    font-size: 20px;
    font-weight: 900;
    color: var(--brown-1);
    letter-spacing: 0;
  }
  .work-platform {
    display: inline-block;
    padding: 3px 9px;
    font-size: 10px;
    font-weight: 900;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    letter-spacing: 0.06em;
  }
  .work-tag {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
  }
  .work-more {
    justify-self: end;
    font-size: 18px;
    font-weight: 900;
    color: var(--muted);
    transition: color 0.2s var(--ease-out-cubic), transform 0.2s var(--ease-out-cubic);
  }

  /* ---------- About ---------- */
  .about-panel {
    max-width: 720px;
    padding: 18px 0 4px;
    border-top: 1px solid var(--line-strong);
  }
  .about-body { width: 100%; min-width: 0; }
  .about-body p {
    font-size: 13.5px;
    line-height: 2;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .about-meta {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed var(--cream-5);
  }
  .about-meta div {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 8px;
    padding: 4px 0;
    font-size: 12.5px;
  }
  .about-meta dt { color: var(--brown-4); font-weight: 900; letter-spacing: 0.05em; }
  .about-meta dd { color: var(--brown-2); }

  /* ---------- Press ---------- */
  .press-card { text-align: center; }
  .press-h { font-size: 14px; font-weight: 900; margin-bottom: 6px; color: var(--brown-1); }
  .press-p { font-size: 12.5px; color: var(--brown-3); margin-bottom: 14px; line-height: 1.85; }

  /* ---------- Contact ---------- */
  .contact-cta {
    padding: 2px 0 16px;
    text-align: left;
  }
  .contact-panel {
    max-width: 720px;
    padding: 18px 0 4px;
    border-top: 1px solid var(--line-strong);
  }
  /* メーラー未起動時に出る保険ヒント */
  .copy-hint {
    margin-top: 10px;
    padding: 10px 12px;
    background: var(--cream-2);
    border: 1px dashed var(--cream-5);
    border-radius: var(--radius-2);
    font-size: 12px;
    line-height: 1.7;
    color: var(--brown-3);
  }
  .copy-hint code {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--brown-1);
    background: rgba(255, 213, 79, 0.25);
    padding: 1px 6px;
    border-radius: 3px;
    word-break: break-all;
  }
  .contact-subhead {
    margin-top: 2px;
    padding-top: 14px;
    border-top: 1px dashed var(--cream-5);
    font-size: 11px;
    font-weight: 900;
    color: var(--brown-4);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .contact-list { list-style: none; margin-top: 2px; }
  .contact-list li {
    display: grid;
    grid-template-columns: 104px minmax(0, 1fr);
    gap: 12px;
    padding: 9px 0;
    border-bottom: 1px dashed var(--cream-5);
    align-items: baseline;
    font-size: 13px;
  }
  .contact-list li:last-child { border-bottom: 0; }
  .contact-list .k { color: var(--brown-4); font-weight: 900; font-size: 12px; letter-spacing: 0.05em; }

  /* ---------- Responsive ---------- */
  @media (max-width: 780px) {
    .hero { padding: 28px 0 14px; }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .hero-copy h1 {
      font-size: clamp(30px, 8.5vw, 39px);
    }
    .hero-lede {
      font-size: 14px;
      line-height: 1.9;
    }
    .hero-poster-img img { max-width: min(72vw, 320px); border-radius: 14px; }
    .hero-actions { margin-top: 16px; gap: 8px; }
    .hero-stats {
      grid-template-columns: repeat(3, 1fr);
      margin-top: 22px;
    }
    .hero-stats dt { font-size: 18px; }
    .hero-stats dd { font-size: 9.5px; }

    .work-row {
      grid-template-columns: 1fr 18px;
      gap: 10px;
      padding: 16px 0;
    }
    .work-no { display: none; }
    .work-title { font-size: 17px; }
    .work-platform { font-size: 10px; padding: 1px 7px; }
    .work-tag { font-size: 12px; line-height: 1.65; }

    .about-meta div {
      grid-template-columns: 70px 1fr;
      gap: 6px;
      font-size: 12px;
    }

    .contact-list li {
      grid-template-columns: 80px 1fr;
      gap: 8px;
      font-size: 12.5px;
      padding: 7px 0;
    }
    .contact-list .k { font-size: 11px; }

    .featured-card {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 24px 18px;
      min-height: 0;
    }
    .featured-pino {
      right: 10px;
      top: 10px;
      width: 62px;
    }
    .featured-media {
      min-height: 310px;
      order: -1;
    }
    .featured-cover {
      width: 76%;
      right: 4%;
      top: 4%;
    }
    .featured-shot {
      width: 42%;
    }
