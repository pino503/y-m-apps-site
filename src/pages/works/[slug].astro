---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

interface Props {
  app: CollectionEntry<"apps">;
}

const { app } = Astro.props;
const { Content } = await app.render();
const { data } = app;
---

<BaseLayout title={`${data.title} — Y.M Apps`} description={data.tagline}>
  <section class="stack-section">
    <div class="container">
      <p class="crumb">
        <a href="/">Home</a> <span>/</span> <a href="/#works">Works</a> <span>/</span> <span>{data.title}</span>
      </p>

      <div class="app-hero card" data-world={data.world}>
        <div class="app-hero-copy">
          <div class="app-tags">
            {data.badges.map((b) => <span class="tag">{b}</span>)}
          </div>
          <div class="app-title-row">
            {data.iconImage && <img class="app-icon" src={data.iconImage} alt="" loading="eager" decoding="async" />}
            <h1 class="app-title">{data.title}</h1>
          </div>
          <p class="app-tagline">{data.tagline}</p>
          {data.storeUrl && !data.unpublished && (
            <a class="btn btn-primary app-cta" href={data.storeUrl} target="_blank" rel="noopener noreferrer">
              {data.storeLabel ?? "ストアで見る"} →
            </a>
          )}
          {data.unpublished && (
            <span class="btn app-cta app-cta-pending" aria-disabled="true" title="ストアでの公開準備中です">
              準備中 — まもなく公開
            </span>
          )}
        </div>

        {(data.coverImage || data.screenshots.length > 0) && (
          <div class="app-hero-media" aria-label={`${data.title} のスクリーンショット`}>
            <img
              src={data.coverImage ?? data.screenshots[0]}
              alt={`${data.title} の画面`}
              loading="eager"
              decoding="async"
            />
          </div>
        )}
      </div>

      <h2 class="section-title">About</h2>
      <div class="card">
        <div class="app-body"><Content /></div>
      </div>

      {data.embedPath && (
        <>
          <h2 class="section-title">Play</h2>
          <div class="card" style="padding:0;overflow:hidden;">
            <div class="game-frame" data-world={data.world}>
              <iframe src={data.embedPath} title={`${data.title} (browser game)`} allow="autoplay; fullscreen" loading="lazy"></iframe>
            </div>
          </div>
          <p style="margin-top:8px;text-align:right;">
            <a href={data.embedPath} target="_blank" rel="noopener noreferrer" style="font-size:12px;font-weight:900;">フルスクリーンで開く →</a>
          </p>
        </>
      )}

      {data.world === "pinokun-stamps" && (
        <>
          <h2 class="section-title">Gallery</h2>
          <div class="card">
            <p style="font-size:12.5px;color:var(--brown-3);margin-bottom:14px;">
              「ぴのくん 友達と遊ぼう」シリーズの全 24 枚。クリックで拡大します。<br />
              他のシリーズや絵文字は LINE STORE のクリエイターページからご覧いただけます。
            </p>
            <div class="stamp-gallery">
              {Array.from({ length: 24 }, (_, i) => i + 1).map((n) => (
                <a class="stamp-tile" href={`/assets/pinokun/stamps/${n}.png`} target="_blank" rel="noopener noreferrer">
                  <img src={`/assets/pinokun/stamps/${n}.png`} alt={`stamp ${n}`} loading="lazy" />
                  <span class="stamp-no">{String(n).padStart(2, "0")}</span>
                </a>
              ))}
            </div>
            <p style="margin-top:14px;text-align:center;">
              <a href={data.storeUrl} target="_blank" rel="noopener noreferrer" style="font-size:12.5px;font-weight:900;">LINE STORE で全シリーズ・絵文字を見る →</a>
            </p>
          </div>
        </>
      )}

      {data.features.length > 0 && (
        <>
          <h2 class="section-title">Features</h2>
          <div class="features">
            {data.features.map((f, i) => (
              <article class="card feature" data-reveal data-reveal-delay={Math.min(i, 5)}>
                <span class="feature-no">{String(i + 1).padStart(2, "0")}</span>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))}
          </div>
        </>
      )}

      {data.screenshots.length > 0 && (
        <>
          <h2 class="section-title">Screenshots</h2>
          <div class="shots">
            {data.screenshots.map((src, i) => (
              <a class="shot-link" href={src} target="_blank" rel="noopener noreferrer">
                <img src={src} alt={`${data.title} screenshot ${i + 1}`} loading="lazy" decoding="async" />
              </a>
            ))}
          </div>
        </>
      )}

      <p style="margin-top: 32px; text-align: center;">
        <a href="/#works" class="btn">← Works に戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .crumb {
    font-size: 11px;
    color: var(--brown-4);
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: 0.06em;
  }
  .crumb span { margin: 0 6px; color: var(--brown-5); }
  .crumb a { color: var(--brown-3); }
  .crumb a:hover { color: var(--orange); }

  .app-hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(280px, 1.14fr);
    gap: 28px;
    align-items: center;
    padding: 30px;
    overflow: hidden;
  }
  .app-hero::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: var(--accent, var(--orange));
    border-radius: var(--radius-2) var(--radius-2) 0 0;
  }
  .app-hero[data-world="inkpress"]          { --accent: #b39472; }
  .app-hero[data-world="playcord"]          { --accent: #4a8a4a; }
  .app-hero[data-world="rainwiper"]         { --accent: #6c9bc9; }
  .app-hero[data-world="sidewalk-defender"] { --accent: #d68a3e; }
  .app-hero[data-world="pinokun-stamps"]    { --accent: #f3b94d; }
  .app-hero[data-world="cosmo-cleaner"]     { --accent: #22ff88; }

  .app-hero-copy { min-width: 0; }
  .app-hero .app-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 14px;
  }
  .app-title {
    font-size: 28px;
    font-weight: 900;
    margin-bottom: 8px;
    color: var(--brown-1);
    letter-spacing: 0.02em;
    line-height: 1.3;
  }
  .app-title-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 8px;
  }
  .app-title-row .app-title { margin-bottom: 0; }
  .app-icon {
    width: 54px;
    height: 54px;
    border-radius: 12px;
    background: #fff;
    border: 1px solid var(--line);
    box-shadow: 0 10px 24px -18px rgba(15, 23, 42, 0.42);
    flex: 0 0 auto;
  }
  .app-tagline {
    font-size: 14px;
    color: var(--brown-3);
    line-height: 1.85;
    margin-bottom: 18px;
  }
  .app-cta { margin-top: 2px; }
  .app-cta-pending {
    display: inline-block;
    padding: 10px 18px;
    color: var(--muted);
    background: #f1ecdc;
    border: 1px dashed var(--line);
    border-radius: 999px;
    font-weight: 900;
    font-size: 13px;
    letter-spacing: 0.06em;
    cursor: not-allowed;
    user-select: none;
  }
  .app-hero-media {
    position: relative;
    min-height: 280px;
    display: grid;
    place-items: center;
    padding: 22px;
    background:
      radial-gradient(circle at 18% 20%, color-mix(in srgb, var(--accent) 28%, transparent), transparent 36%),
      color-mix(in srgb, var(--surface-soft) 72%, transparent);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    overflow: hidden;
  }
  .app-hero-media img {
    width: 100%;
    max-height: 520px;
    object-fit: contain;
    border-radius: var(--radius-2);
    box-shadow: 0 22px 54px -36px rgba(15, 23, 42, 0.72);
  }

  .app-body p { font-size: 13.5px; line-height: 1.95; margin-bottom: 8px; }

  /* ---------- Features (notebook entries) ----------
     左端に細い赤線（ノートのマージン罫）、左マージンに通し番号。
     紙の上にメモを取った感じを目指す。 */
  .features { display: grid; gap: 12px; }
  .feature {
    position: relative;
    padding: 18px 20px 18px 56px;
  }
  .feature::before {
    /* 赤いマージン罫線 */
    content: "";
    position: absolute;
    left: 40px;
    top: 14px;
    bottom: 14px;
    width: 1.5px;
    background: rgba(214, 96, 96, 0.45);
  }
  .feature-no {
    position: absolute;
    left: 14px;
    top: 18px;
    font-size: 18px;
    font-weight: 900;
    color: var(--orange);
    font-family: var(--font-display);
    line-height: 1;
    letter-spacing: 0;
  }
  .feature h3 {
    font-size: 15px;
    margin-bottom: 6px;
    color: var(--brown-1);
    font-weight: 900;
  }
  .feature p {
    font-size: 13px;
    color: var(--brown-3);
    line-height: 1.85;
  }

  /* ---------- Screenshots ---------- */
  .shots {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .shot-link {
    display: block;
    padding: 10px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-2);
    text-decoration: none;
    transition: transform 0.24s var(--ease-out-cubic), box-shadow 0.24s var(--ease-out-cubic);
  }
  .shot-link:hover {
    opacity: 1;
    transform: translateY(-2px);
    box-shadow: 0 18px 42px -34px rgba(15, 23, 42, 0.58);
  }
  .shots img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-2);
    background: #fff;
  }

  /* ---------- Game embed ---------- */
  .game-frame {
    aspect-ratio: 9 / 16;
    max-height: 720px;
    background: #0a0e1a;
    margin: 0 auto;
    max-width: 360px;
  }
  /* COSMO CLEANER は内部解像度が画面ARに合わせて伸縮するので、
     iframe は横幅を許して広い画面ではより広い視野を出す */
  .game-frame[data-world="cosmo-cleaner"] {
    aspect-ratio: 5 / 8;
    max-width: min(560px, 100%);
    max-height: 820px;
  }
  .game-frame iframe { width: 100%; height: 100%; border: 0; display: block; }

  /* ---------- Stamp gallery (cream paper tiles) ---------- */
  .stamp-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(86px, 1fr));
    gap: 8px;
  }
  .stamp-tile {
    position: relative;
    background: var(--cream-1);
    border: 1px solid rgba(140, 110, 70, 0.14);
    border-radius: var(--radius-2);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    text-decoration: none;
    transition: transform 0.3s var(--ease-out-quint), box-shadow 0.3s var(--ease-out-quint);
    box-shadow: 0 1px 1px rgba(120, 90, 50, 0.06);
  }
  .stamp-tile:hover {
    transform: translateY(-2px) rotate(-1deg);
    box-shadow:
      0 1px 1px rgba(120, 90, 50, 0.08),
      0 6px 14px -8px rgba(120, 90, 50, 0.22);
    text-decoration: none;
  }
  .stamp-tile img { width: 100%; height: 100%; object-fit: contain; }
  .stamp-no {
    position: absolute;
    bottom: 4px;
    right: 6px;
    font-size: 9px;
    font-weight: 900;
    color: var(--brown-5);
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 780px) {
    .app-hero {
      grid-template-columns: 1fr;
      padding: 22px 16px 20px;
    }
    .app-title { font-size: 24px; }
    .app-icon {
      width: 46px;
      height: 46px;
      border-radius: 10px;
    }
    .app-tagline { font-size: 13px; }
    .app-hero-media {
      min-height: 220px;
      padding: 12px;
      max-width: 340px;
      width: 100%;
      margin: 8px auto 0;
    }
  }

  @media (max-width: 520px) {

    .feature { padding: 14px 16px 14px 48px; }
    .feature::before { left: 34px; top: 12px; bottom: 12px; }
    .feature-no { left: 12px; top: 14px; font-size: 16px; }
    .feature h3 { font-size: 14px; }
    .feature p { font-size: 12.5px; }
  }
</style>
