---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

interface Props {
  app: CollectionEntry<"apps">;
}

const { app } = Astro.props;
const { Content } = await app.render();
const { data } = app;

const writings = (await getCollection("writings"))
  .filter((w) => w.data.relatedApp === app.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const worldClass =
  data.world === "sidewalk-defender" ? "sidewalk" :
  data.world === "pinokun-stamps" ? "stamps" : data.world;
---

<BaseLayout title={`${data.title} — Y.M Apps`} description={data.tagline}>
  <section class="stack-section">
    <div class="container">
      <p class="crumb">
        <a href="/">Home</a> <span>/</span> <a href="/#works">Works</a> <span>/</span> <span>{data.title}</span>
      </p>

      {/* World Hero */}
      <div class="app-hero card" data-world={data.world} data-reveal>
        <div class={`app-hero-bg world-mock--${worldClass}`}>
          {data.world === "rainwiper" && <><div class="drops"></div><div class="wiper"></div></>}
        </div>
        <div class="app-hero-text">
          <h1>{data.title}</h1>
          <p class="app-tagline">{data.tagline}</p>
          <div class="app-tags">
            {data.badges.map((b) => <span class="tag">{b}</span>)}
          </div>
          {data.storeUrl && (
            <a class="btn btn-primary" href={data.storeUrl} target="_blank" rel="noopener noreferrer" style="margin-top:10px;">
              {data.storeLabel ?? "ストアで見る"} →
            </a>
          )}
        </div>
      </div>

      <h2 class="section-title">About</h2>
      <div class="card">
        <div class="app-body"><Content /></div>
      </div>

      {data.embedPath && (
        <>
          <h2 class="section-title">Play</h2>
          <div class="card" style="padding:0;overflow:hidden;">
            <div class="game-frame">
              <iframe src={data.embedPath} title={`${data.title} (browser game)`} allow="autoplay; fullscreen" loading="lazy"></iframe>
            </div>
          </div>
          <p style="margin-top:8px;text-align:right;">
            <a href={data.embedPath} target="_blank" rel="noopener noreferrer" style="font-size:12px;font-weight:900;">フルスクリーンで開く →</a>
          </p>
        </>
      )}

      {data.world === "pinokun-stamps" && (
        <>
          <h2 class="section-title">Gallery</h2>
          <div class="card">
            <p style="font-size:12.5px;color:var(--brown-3);margin-bottom:14px;">
              「ぴのくん 友達と遊ぼう」シリーズの全 24 枚。クリックで拡大します。<br />
              他のシリーズや絵文字は LINE STORE のクリエイターページからご覧いただけます。
            </p>
            <div class="stamp-gallery">
              {Array.from({ length: 24 }, (_, i) => i + 1).map((n) => (
                <a class="stamp-tile" href={`/assets/pinokun/stamps/${n}.png`} target="_blank" rel="noopener noreferrer">
                  <img src={`/assets/pinokun/stamps/${n}.png`} alt={`stamp ${n}`} loading="lazy" />
                  <span class="stamp-no">{String(n).padStart(2, "0")}</span>
                </a>
              ))}
            </div>
            <p style="margin-top:14px;text-align:center;">
              <a href={data.storeUrl} target="_blank" rel="noopener noreferrer" style="font-size:12.5px;font-weight:900;">LINE STORE で全シリーズ・絵文字を見る →</a>
            </p>
          </div>
        </>
      )}

      {data.features.length > 0 && (
        <>
          <h2 class="section-title">Features</h2>
          <div class="features">
            {data.features.map((f, i) => (
              <article class="card feature" data-reveal data-reveal-delay={Math.min(i, 5)}>
                <span class="feature-no">{String(i + 1).padStart(2, "0")}</span>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))}
          </div>
        </>
      )}

      {data.screenshots.length > 0 && (
        <>
          <h2 class="section-title">Screenshots</h2>
          <div class="shots">
            {data.screenshots.map((src) => (
              <img src={src} alt="" loading="lazy" decoding="async" />
            ))}
          </div>
        </>
      )}

      {writings.length > 0 && (
        <>
          <h2 class="section-title">Related Writings</h2>
          <div class="card">
            <ul class="ruled-list">
              {writings.map((w) => (
                <li>
                  <a href={w.data.url} target="_blank" rel="noopener noreferrer">{w.data.title}</a>
                  <span class="meta">{w.data.date.replace(/-/g, "/").slice(2)}</span>
                </li>
              ))}
            </ul>
          </div>
        </>
      )}

      <p style="margin-top: 32px; text-align: center;">
        <a href="/#works" class="btn">← Works に戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .crumb {
    font-size: 11px;
    color: var(--brown-4);
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: 0.06em;
  }
  .crumb span { margin: 0 6px; color: var(--brown-5); }
  .crumb a { color: var(--brown-3); }
  .crumb a:hover { color: var(--orange); }

  .app-hero { padding: 0; overflow: hidden; }
  .app-hero-bg {
    aspect-ratio: 16 / 6;
    padding: 18px;
    border-bottom: 2px solid var(--yellow);
    position: relative;
  }
  .app-hero-text { padding: 18px 20px 22px; }
  .app-hero-text h1 {
    font-size: 24px;
    font-weight: 900;
    margin-bottom: 8px;
    color: var(--brown-1);
    letter-spacing: 0.01em;
  }
  .app-tagline {
    font-size: 13px;
    color: var(--brown-3);
    line-height: 1.85;
    margin-bottom: 12px;
  }
  .app-tags { display: flex; flex-wrap: wrap; gap: 4px; }

  .app-body p { font-size: 13.5px; line-height: 1.95; margin-bottom: 8px; }

  .features { display: grid; gap: 10px; }
  .feature { position: relative; padding-left: 50px; }
  .feature-no {
    position: absolute;
    left: 14px;
    top: 14px;
    font-size: 22px;
    color: var(--orange);
    opacity: 0.45;
    font-weight: 900;
    line-height: 1;
  }
  .feature h3 { font-size: 14px; margin-bottom: 4px; color: var(--brown-1); font-weight: 900; }
  .feature p { font-size: 12.5px; color: var(--brown-3); line-height: 1.85; }

  .shots {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }
  .shots img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-2);
    border: 2px solid var(--yellow);
    background: #fff;
  }

  .game-frame {
    aspect-ratio: 9 / 16;
    max-height: 720px;
    background: #0a0e1a;
    margin: 0 auto;
    max-width: 360px;
  }
  .game-frame iframe { width: 100%; height: 100%; border: 0; display: block; }

  .stamp-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(86px, 1fr));
    gap: 8px;
  }
  .stamp-tile {
    position: relative;
    background: linear-gradient(180deg, #e8f3fc, #cfe7fb);
    border: 2px solid var(--yellow);
    border-radius: var(--radius-2);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    text-decoration: none;
    transition: transform 0.3s var(--ease-out-quint);
  }
  .stamp-tile:hover {
    transform: translateY(-2px) rotate(-1deg);
    border-color: var(--orange);
    text-decoration: none;
  }
  .stamp-tile img { width: 100%; height: 100%; object-fit: contain; }
  .stamp-no {
    position: absolute;
    bottom: 4px;
    right: 6px;
    font-size: 9px;
    font-weight: 900;
    color: rgba(31,78,138,0.55);
  }
</style>
