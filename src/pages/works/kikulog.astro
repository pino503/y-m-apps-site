---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Bespoke landing page for キクログ (a live web tool, not a store app).
// Ported from the Claude Design file「キクログ紹介.dc.html」(project キクログUI).
// We keep BaseLayout's site header/footer/SEO/transitions and drop the design's
// own <nav>/<footer> so the page stays consistent with the other works pages.
// Title / tagline / tool URL come from the content collection (apps/kikulog.md).
const apps = await getCollection("apps");
const app = apps.find((a) => a.slug === "kikulog")!;
const { data } = app;
const tool = data.storeUrl;
---

<BaseLayout title={`${data.title} — Y.M Apps`} description={data.tagline} lang="ja">
  <div class="kk-landing" style="width: 100%; background: #F6F2E9; color: #2D3B41; line-height: 1.85; font-family: 'Zen Kaku Gothic New', sans-serif; overflow-x: hidden;">

    <!-- breadcrumb (site navigation) -->
    <div style="max-width: 1080px; margin: 0 auto; padding: 20px 28px 0;">
      <nav style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: #8A9499; font-weight: 500;">
        <a href="/" style="color: #5E6E74;">Home</a>
        <span style="color: #C9BFA8;">/</span>
        <a href="/#works" style="color: #5E6E74;">Works</a>
        <span style="color: #C9BFA8;">/</span>
        <span style="color: #2E7E99; font-weight: 700;">{data.title}</span>
      </nav>
    </div>

    <!-- ===== Hero ===== -->
    <header id="top" style="position: relative; overflow: hidden; padding: 64px 28px 64px;">
      <div style="position: absolute; top: -160px; right: -140px; width: 520px; height: 520px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, rgba(123,191,166,.30), rgba(123,191,166,0) 70%);"></div>
      <div style="position: absolute; top: 40px; left: -180px; width: 460px; height: 460px; border-radius: 50%; background: radial-gradient(circle at 50% 50%, rgba(120,178,200,.22), rgba(120,178,200,0) 70%);"></div>

      <div style="position: relative; max-width: 860px; margin: 0 auto; text-align: center;">
        <div class="kkup" style="display: inline-flex; align-items: center; gap: 8px; padding: 7px 15px; border-radius: 30px; background: #EAF3EF; border: 1px solid #D2E6DC; margin-bottom: 26px;">
          <span style="width: 7px; height: 7px; border-radius: 50%; background: #5C9E7C;"></span>
          <span style="font-size: 13px; font-weight: 700; color: #4A8268;">就労支援・福祉の現場のための面談支援ツール</span>
        </div>
        <h1 class="kkup kkd1" style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 900; font-size: clamp(23px, 6.4vw, 46px); line-height: 1.5; letter-spacing: .01em; color: #28373D; margin: 0 0 22px;">
          面談の記録づくりを、<br>聞きながら<span style="color: #2E7E99;">その場で</span>。
        </h1>
        <p class="kkup kkd2" style="font-size: 18px; color: #5E6E74; max-width: 600px; margin: 0 auto 34px; line-height: 1.95;">
          記録づくりの負担を減らして、目の前の相手との時間に集中できるように。<br>ブラウザだけで動く、静かな業務ツールです。
        </p>
        <div class="kkup kkd3 kk-hero-cta" style="display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; margin-bottom: 22px;">
          <a href={tool} target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 9px; padding: 15px 30px; border-radius: 14px; background: #2E7E99; color: #fff; font-size: 16px; font-weight: 700; box-shadow: 0 8px 22px rgba(46,126,153,.26);">
            ツールを開く
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
          </a>
          <a href="#features" style="display: inline-flex; align-items: center; gap: 8px; padding: 15px 26px; border-radius: 14px; background: #FFFFFF; color: #3C5158; font-size: 16px; font-weight: 700; border: 1px solid #E2DBCC;">できることを見る</a>
        </div>
        <div style="display: flex; align-items: center; justify-content: center; gap: 18px; flex-wrap: wrap; font-size: 13px; color: #8A9499; font-weight: 500;">
          <span style="display: inline-flex; align-items: center; gap: 6px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#5C9E7C" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>インストール不要</span>
          <span style="display: inline-flex; align-items: center; gap: 6px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#5C9E7C" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>PC・スマホ対応</span>
          <span style="display: inline-flex; align-items: center; gap: 6px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#5C9E7C" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>データは端末の中だけ</span>
        </div>
      </div>

      <!-- product shot in browser frame -->
      <div class="kkup kkd3" style="position: relative; max-width: 940px; margin: 54px auto 0;">
        <div style="border-radius: 18px; overflow: hidden; background: #fff; border: 1px solid #E4DDCE; box-shadow: 0 30px 70px -28px rgba(40,55,61,.35);">
          <div style="height: 38px; background: #F1ECE1; border-bottom: 1px solid #E4DDCE; display: flex; align-items: center; padding: 0 15px; gap: 8px;">
            <span style="width: 11px; height: 11px; border-radius: 50%; background: #E0B8B0;"></span>
            <span style="width: 11px; height: 11px; border-radius: 50%; background: #E6D3A8;"></span>
            <span style="width: 11px; height: 11px; border-radius: 50%; background: #B9D6BE;"></span>
            <span style="margin: 0 auto; padding: 3px 16px; background: #FFFFFF; border: 1px solid #E4DDCE; border-radius: 20px; font-size: 11.5px; color: #9AA3A8; font-weight: 500;">kikulog.pages.dev</span>
          </div>
          <img src="/assets/apps/kikulog-shot-ui.png" alt="キクログの面談画面" style="display: block; width: 100%;" />
        </div>
      </div>
    </header>

    <!-- ===== About / 誠実な理由 ===== -->
    <section id="about" style="padding: 84px 28px;">
      <div style="max-width: 760px; margin: 0 auto;">
        <div style="display: flex; align-items: center; gap: 10px; justify-content: center; margin-bottom: 26px;">
          <span style="width: 30px; height: 2px; background: #C9BFA8;"></span>
          <span style="font-size: 13px; font-weight: 700; color: #9A8E73; letter-spacing: .14em;">WHY WE MADE IT</span>
          <span style="width: 30px; height: 2px; background: #C9BFA8;"></span>
        </div>
        <div class="kk-about-card" style="position: relative; background: #FFFFFF; border: 1px solid #ECE4D4; border-radius: 22px; padding: 46px 48px;">
          <svg width="42" height="42" viewBox="0 0 24 24" fill="#E0EDE7" style="position: absolute; top: 26px; left: 30px;"><path d="M9.5 4C6 5.5 4 9 4 13v7h7v-7H7.5C7.5 9.5 9 7 11 6L9.5 4Zm9 0C15 5.5 13 9 13 13v7h7v-7h-3.5c0-3.5 1.5-6 3.5-7L18.5 4Z"></path></svg>
          <p style="position: relative; font-size: 19px; line-height: 2.1; color: #38474D; margin: 0; font-weight: 500; text-align: center;">
            就労継続支援をはじめとする福祉の現場で、利用者さんと話しながら<br>面談の記録を<span style="color: #2E7E99; font-weight: 700;">その場で形にできる道具</span>がほしくて作りました。
          </p>
          <p style="font-size: 16px; line-height: 2.05; color: #6B7A80; margin: 22px 0 0; text-align: center;">
            記録づくりの負担を減らして、目の前の相手との時間に集中できるように ── そんな静かな業務ツールを目指しています。ブラウザだけで動き、面談データも録音した音声も、あなたの端末から外に出ません。
          </p>
        </div>
      </div>
    </section>

    <!-- ===== Features ===== -->
    <section id="features" style="padding: 24px 28px 84px;">
      <div style="max-width: 1080px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 46px;">
          <h2 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 32px; color: #28373D; margin: 0 0 12px;">できること</h2>
          <p style="font-size: 16px; color: #7A878C; margin: 0;">面談の準備から記録の共有まで、ひと続きで。</p>
        </div>
        <div class="kk-feature-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">

          <div style="background: #FFFFFF; border: 1px solid #ECE4D4; border-radius: 20px; padding: 32px 30px;">
            <div style="width: 52px; height: 52px; border-radius: 15px; background: #EAF3EF; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2E7E99" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6h11M9 12h11M9 18h11"></path><circle cx="4" cy="6" r="1.4"></circle><circle cx="4" cy="12" r="1.4"></circle><circle cx="4" cy="18" r="1.4"></circle></svg>
            </div>
            <h3 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 20px; color: #2A3A40; margin: 0 0 11px;">面談の流れをそのままガイド</h3>
            <p style="font-size: 15px; color: #687479; margin: 0; line-height: 1.95;">事前準備・導入・アセスメント・整理・記録作成までを5ステップで案内。聞きたいことや声かけのヒントも出るので、面談そのものに集中できます。</p>
          </div>

          <div style="background: #FFFFFF; border: 1px solid #ECE4D4; border-radius: 20px; padding: 32px 30px;">
            <div style="width: 52px; height: 52px; border-radius: 15px; background: #EDF3EE; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#4F8E6C" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>
            </div>
            <h3 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 20px; color: #2A3A40; margin: 0 0 11px;">話しながら記録が組み上がる</h3>
            <p style="font-size: 15px; color: #687479; margin: 0; line-height: 1.95;">回答を入れていくだけで記録テキストを自動生成。最後にそのまま編集してコピーでき、CSVで履歴を書き出して共有もできます。</p>
          </div>

          <div style="background: #FFFFFF; border: 1px solid #ECE4D4; border-radius: 20px; padding: 32px 30px;">
            <div style="width: 52px; height: 52px; border-radius: 15px; background: #EAF3EF; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2E7E99" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"></rect><path d="M5 10a7 7 0 0 0 14 0M12 17v5"></path></svg>
            </div>
            <h3 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 20px; color: #2A3A40; margin: 0 0 11px;">音声録音 → 文字起こしは外部で</h3>
            <p style="font-size: 15px; color: #687479; margin: 0; line-height: 1.95;">面談を録音してMP3で書き出し、NotebookLM等にそのまま渡せます。録音の前に同意確認をはさみ、音声は端末の中だけに保持します。</p>
          </div>

          <div style="background: #FFFFFF; border: 1px solid #ECE4D4; border-radius: 20px; padding: 32px 30px;">
            <div style="width: 52px; height: 52px; border-radius: 15px; background: #EDF3EE; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#4F8E6C" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
            </div>
            <h3 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 20px; color: #2A3A40; margin: 0 0 11px;">データは端末の中だけ</h3>
            <p style="font-size: 15px; color: #687479; margin: 0; line-height: 1.95;">面談データも録音した音声もサーバーに送りません。すべてご利用の端末のブラウザに保存され、外に出るのはあなたがアップロードした時だけです。</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== Flow / 5 steps ===== -->
    <section style="padding: 76px 28px; background: #EFEADD; border-top: 1px solid #E7E0D2; border-bottom: 1px solid #E7E0D2;">
      <div style="max-width: 1000px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 48px;">
          <h2 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 32px; color: #28373D; margin: 0 0 12px;">面談の5ステップ</h2>
          <p style="font-size: 16px; color: #7A878C; margin: 0;">迷わず進める。記録は終わったときにはもうできている。</p>
        </div>
        <div class="kk-steps" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px;">
          <div style="text-align: center;">
            <div style="width: 50px; height: 50px; border-radius: 50%; background: #2E7E99; color: #fff; font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 19px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; box-shadow: 0 6px 16px rgba(46,126,153,.28);">1</div>
            <div style="font-size: 15px; font-weight: 700; color: #2A3A40; margin-bottom: 5px;">事前準備</div>
            <div style="font-size: 12.5px; color: #7A878C; line-height: 1.7;">過去の記録から仮説を整理</div>
          </div>
          <div style="text-align: center;">
            <div style="width: 50px; height: 50px; border-radius: 50%; background: #3C8AA3; color: #fff; font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 19px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; box-shadow: 0 6px 16px rgba(46,126,153,.22);">2</div>
            <div style="font-size: 15px; font-weight: 700; color: #2A3A40; margin-bottom: 5px;">導入</div>
            <div style="font-size: 12.5px; color: #7A878C; line-height: 1.7;">声かけ例で話しやすく</div>
          </div>
          <div style="text-align: center;">
            <div style="width: 50px; height: 50px; border-radius: 50%; background: #4A97A0; color: #fff; font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 19px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; box-shadow: 0 6px 16px rgba(74,151,160,.22);">3</div>
            <div style="font-size: 15px; font-weight: 700; color: #2A3A40; margin-bottom: 5px;">アセスメント</div>
            <div style="font-size: 12.5px; color: #7A878C; line-height: 1.7;">本人の言葉を聞き取る</div>
          </div>
          <div style="text-align: center;">
            <div style="width: 50px; height: 50px; border-radius: 50%; background: #549B8A; color: #fff; font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 19px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; box-shadow: 0 6px 16px rgba(84,155,138,.22);">4</div>
            <div style="font-size: 15px; font-weight: 700; color: #2A3A40; margin-bottom: 5px;">情報の整理</div>
            <div style="font-size: 12.5px; color: #7A878C; line-height: 1.7;">支援の方向性を考える</div>
          </div>
          <div style="text-align: center;">
            <div style="width: 50px; height: 50px; border-radius: 50%; background: #5C9E7C; color: #fff; font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 19px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; box-shadow: 0 6px 16px rgba(92,158,124,.28);">5</div>
            <div style="font-size: 15px; font-weight: 700; color: #2A3A40; margin-bottom: 5px;">記録作成</div>
            <div style="font-size: 12.5px; color: #7A878C; line-height: 1.7;">確認してコピー・書き出し</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Install / アプリのように使う ===== -->
    <section id="install" style="padding: 84px 28px;">
      <div style="max-width: 1080px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 14px;">
          <h2 style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 32px; color: #28373D; margin: 0 0 12px;">アプリのように使う</h2>
          <p style="font-size: 16px; color: #7A878C; margin: 0 auto; max-width: 660px; line-height: 1.95;">ブラウザの「インストール」機能で、デスクトップやホーム画面にアイコンを置けます。次からはアイコンを押すだけ。独立した画面で、全画面で開けます。</p>
        </div>
        <div style="display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; margin: 26px 0 40px; font-size: 13px; color: #5E6E74; font-weight: 600;">
          <span style="display: inline-flex; align-items: center; gap: 7px; background: #EAF3EF; border: 1px solid #D2E6DC; border-radius: 30px; padding: 8px 16px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2E7E99" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="13" rx="2"></rect><path d="M8 21h8M12 16v5"></path></svg>独立ウィンドウで起動</span>
          <span style="display: inline-flex; align-items: center; gap: 7px; background: #EDF3EE; border: 1px solid #D5E6D9; border-radius: 30px; padding: 8px 16px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4F8E6C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h18M3 12h18M3 17h18"></path></svg>タブに埋もれない</span>
          <span style="display: inline-flex; align-items: center; gap: 7px; background: #EAF3EF; border: 1px solid #D2E6DC; border-radius: 30px; padding: 8px 16px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2E7E99" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17l9-10"></path></svg>オフラインでも開ける</span>
        </div>

        <div class="kk-install-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">

          <!-- Windows / Mac -->
          <div style="background: #FFFFFF; border: 1px solid #ECE4D4; border-radius: 20px; padding: 30px 28px; display: flex; flex-direction: column;">
            <div style="display: flex; align-items: center; gap: 13px; margin-bottom: 22px;">
              <span style="width: 50px; height: 50px; border-radius: 14px; background: #EAF3EF; display: flex; align-items: center; justify-content: center;">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2E7E99" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg>
              </span>
              <div>
                <div style="font-family: 'Zen Maru Gothic', sans-serif; font-weight: 700; font-size: 17px; line-height: 1.3; white-space: nowrap; color: #2A3A40;">Windows・Mac</div>
                <div style="font-size: 12.5px; color: #9AA3A8; font-weight: 600;">Chrome・Edge</div>
              </div>
            </div>
            <div style="display: flex; flex-direction: column; gap: 14px;">
              <div style="display: flex; gap: 12px;">
                <span style="flex: none; width: 23px; height: 23px; border-radius: 50%; background: #EAF3EF; color: #2E7E99; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center;">1</span>
                <span style="font-size: 14px; color: #4C5A60; line-height: 1.75;">キクログをブラウザで開く</span>
              </div>
              <div style="display: flex; gap: 12px;">
                <span style="flex: none; width: 23px; height: 23px; border-radius: 50%; background: #EAF3EF; color: #2E7E99; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center;">2</span>
                <span style="font-size: 14px; color: #4C5A60; line-height: 1.75;">アドレスバー右の<span style="display: inline-flex; align-items: center; gap: 3px; background: #F1ECE1; border: 1px solid #E4DDCE; border-radius: 6px; padding: 1px 6px; margin: 0 2px; font-weight: 700; color: #3C5158; vertical-align: middle;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"></rect><path d="M12 8v8M8 12h8"></path></svg></span>インストールアイコンをクリック</span>
              </div>
              <div style="display: flex; gap: 12px;">
                <span style="flex: none; width: 23px; height: 23px; border-radius: 50%; background: #EAF3EF; color: #2E7E99; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center;">3</span>
                <span style="font-size: 14px; color: #4C5A60; line-height: 1.75;">「インストール」を選ぶ</span>
              </div>
            </div>
            <div style="margin-top: auto; padding-top: 18px;"><p style="font-size: 12.5px; color: #8A9499; margin: 0; line-height: 1.7; border-top: 1px dashed #E7E0D2; padding-top: 14px;">デスクトップ・スタート・Dockにアイコンが追加されます。</p></div>
          </div>

          <!-- iPhone / iPad -->
