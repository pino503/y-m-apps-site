---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/detail.css";
import { getCollection } from "astro:content";

// 斬刹 -ZANSETSU- の個別ページ。メタデータは content collection から取得し、
// レイアウトは works/cosmo-cleaner.astro のパターンを踏襲する。
const apps = await getCollection("apps");
const app = apps.find((a) => a.slug === "zansetsu")!;
const { data } = app;

const playUrl = data.storeUrl!;

const features = [
  { title: "三段構えの読み合い", body: "上段・中段・下段で、攻撃の振り方と狙える部位が変わります。相手の振りかぶりを見て、潰すか、躱すか、刃を合わせて鍔迫り合いに持ち込むか。" },
  { title: "HPではなく部位ダメージ", body: "頭に入れば一撃で決着。腕を斬られれば剣が鈍り、足を斬られれば歩けなくなる。深手は腕ごと飛びます（流血・欠損の表現は設定で変えられます）。" },
  { title: "カウンターと見切り返し", body: "敵の頭上に▼が出た刹那に斬ればカウンターの一閃。逆に敵の見切りが白く閃いたら、その瞬間のステップで空振りさせて返せます。" },
  { title: "溜め斬りとフェイント", body: "強攻撃は押しっぱなしで溜められ、最大の一撃は四肢を断ち飛ばします。振りかぶりは寸止め（フェイント）もできるので、溜めをわざと見せて誘う駆け引きも。" },
  { title: "剣豪列伝と必殺技", body: "武蔵、小次郎、卜伝、巴御前……史実と伝承の剣豪十六人が、それぞれの姿と剣風で現れます。金の技名が閃いたら必殺の合図。どの技にも必ず対処があります。" },
  { title: "百人斬りと全国ランキング", body: "倒すたびに次の刺客が現れる連戦モード。傷は治らず、10人ごとに剣豪が、100人目には鎧武者が立ちはだかります。記録はかな文字で名を刻んで全国で競えます。" },
];

const weapons = [
  { k: "刀", label: "バランス型・弾きに強い" },
  { k: "二刀", label: "二連撃・近距離" },
  { k: "槍", label: "最長間合い・深突き" },
  { k: "薙刀", label: "横薙ぎで足狩り" },
  { k: "大剣", label: "ガードごと叩き割る" },
  { k: "鎖鎌", label: "遠間の分銅・足搦め" },
];

const otherWorks = [
  { slug: "cosmo-cleaner", name: "COSMO CLEANER", desc: "CRT風の宇宙清掃シューティング。", icon: "/assets/apps/cosmo-cleaner-icon.png" },
  { slug: "sidewalk-defender", name: "Sidewalk Defender", desc: "80年代アーケード風アクション。", icon: "/assets/apps/sidewalk-defender-cover.png" },
  { slug: "playcord", name: "PLAYCORD", desc: "リアルな野球人生シミュレーション。", icon: "/assets/apps/playcord-icon.png" },
];
---

<BaseLayout title={`${data.title} — Y.M Apps`} description="間合いを計って、一太刀で決める。月夜の境内で野武士と斬り合う、1対1の果たし合い。">
  <section class="stack-section">
    <div class="container detail-page">

      <nav class="crumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/#works">Works</a><span class="sep">/</span>
        <span class="cur">{data.title}</span>
      </nav>

      <section class="detail-hero" data-reveal>
        <div class="hero-built hb-night">
          <div class="hb-text">
            <span class="hb-icon"><img src={data.iconImage} alt="" /></span>
            <h1>{data.title}</h1>
            <p class="hb-tag">間合いを計って、一太刀で決める。月夜の境内で斬り合う、1対1の果たし合い。</p>
            <div class="hb-badges"><span class="badge-new">NEW</span><span class="chip">Webゲーム</span><span class="chip">ブラウザ</span></div>
          </div>
          <div class="hb-visual"><img src={data.coverImage} alt={`${data.title} のゲーム画面`} /></div>
        </div>

        <div class="card meta-bar">
          <div class="mb-status"><span class="badge-live">公開中 — ブラウザでプレイ可能</span></div>
          <div class="mb-chips"><span class="chip">Webゲーム</span><span class="chip chip-gold">剣戟決闘アクション</span></div>
          <div class="mb-actions">
            <a class="btn btn-primary" href={playUrl} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 3l14 9-14 9V3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path></svg>
              ブラウザでプレイ
            </a>
          </div>
        </div>
      </section>

      <div class="detail-body">

        <section class="block" data-reveal>
          <span class="lede">ABOUT</span>
          <h2>このゲームについて</h2>
          <div class="about-text">
            <p>月夜の境内に、刀を提げた野武士が立ちはだかります。体力ゲージはなく、頭・胴・腕・足のどこを斬られたかで戦況が変わっていく、1対1の斬り合いです。</p>
            <p class="pull">月明かりの下、間合いを計って、一瞬で決める ── そんな果たし合いの緊張感を目指した一本です。</p>
          </div>
        </section>

        <section class="block" data-reveal>
          <span class="lede">FEATURES</span>
          <h2>遊びどころ</h2>
          <div class="features">
            {features.map((f, i) => (
              <div class="feature">
                <span class="fnum">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{f.title}</h3>
                  <p>{f.body}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="block" data-reveal>
          <span class="lede">SCREENS</span>
          <h2>ゲーム画面</h2>
          <div class="shots wide">
            <div class="shot"><img src="/assets/zansetsu/shot-title.png" alt={`${data.title} タイトル画面`} loading="lazy" decoding="async" /></div>
            <div class="shot"><img src="/assets/zansetsu/shot-fight.png" alt={`${data.title} 決闘画面 ― 刀対薙刀`} loading="lazy" decoding="async" /></div>
            <div class="shot"><img src="/assets/zansetsu/shot-survival.png" alt={`${data.title} 百人斬りモード`} loading="lazy" decoding="async" /></div>
            <div class="shot"><img src="/assets/zansetsu/shot-result.png" alt={`${data.title} 決着の瞬間`} loading="lazy" decoding="async" /></div>
          </div>
        </section>

        <section class="block" data-reveal>
          <span class="lede">RANKING</span>
          <h2>全国ランキング — 百人斬り</h2>
          <p class="rank-lead">
            百人斬りで散るまでに何人斬れたか。全国の番付がここに並びます。
            討死の画面で「全国に名を刻む」と入れた名前が、そのまま載ります。
          </p>
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link href="https://fonts.googleapis.com/css2?family=Yuji+Syuku&display=swap" rel="stylesheet" />
          <div class="kwr" aria-label="百人斬り番付（瓦版）">
            <span class="kwr-seal">斬</span>
            <p class="kwr-kicker">— 瓦 版 —</p>
            <p class="kwr-title">百人斬り番付</p>
            <p class="kwr-sub">天下に名乗りを上げし剣士たち</p>
            <div class="rank-grid">
              {['易しい', '普通', '難しい'].map((label, d) => (
                <div class="rank-col" data-diff={d}>
                  <h3 class="rank-head"><span>{label}</span></h3>
                  <ol class="rank-list"><li class="rank-empty">読み込み中……</li></ol>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="block" data-reveal>
          <span class="lede">HOW TO PLAY</span>
          <h2>操作方法</h2>
          <div class="howto">

            <div class="howto-row">
              <span class="howto-icon">🚶</span>
              <div class="howto-body">
                <h3>移動・ステップ</h3>
                <div class="howto-keys">
                  <div class="howto-key"><span class="plat">スマホ</span><p>◀▶ボタンで移動、「迅」で素早いステップ。</p></div>
                  <div class="howto-key"><span class="plat">PC</span><p><kbd>A</kbd><kbd>D</kbd>（<kbd>←</kbd><kbd>→</kbd>）で移動、<kbd>Shift</kbd> でステップ。</p></div>
                </div>
                <p class="howto-tip">間合いの管理がすべての基本。長物相手は懐に潜ると浅当たりにできます。</p>
              </div>
            </div>

            <div class="howto-row">
              <span class="howto-icon">🗡️</span>
              <div class="howto-body">
                <h3>構えを切り替える（上段・中段・下段）</h3>
                <div class="howto-keys">
                  <div class="howto-key"><span class="plat">スマホ</span><p>「上・中・下」ボタンで切替。いまの構えが光ります。</p></div>
                  <div class="howto-key"><span class="plat">PC</span><p><kbd>W</kbd> / <kbd>S</kbd>（<kbd>↑</kbd><kbd>↓</kbd>）で切替。</p></div>
                </div>
                <p class="howto-tip">構えで攻撃の軌道と狙う部位が変わります。振りかぶり中の相手の頭上に段（上/中/下）が出るので、「どこを狙われるか」を読む合図に。同じ段で斬り込めば鍔迫り合いに持ち込めます。</p>
              </div>
            </div>

            <div class="howto-row">
              <span class="howto-icon">⚔️</span>
              <div class="howto-body">
                <h3>攻撃・溜め斬り</h3>
                <div class="howto-keys">
                  <div class="howto-key"><span class="plat">スマホ</span><p>「斬」で斬撃、「強」で強攻撃。「強」長押しで溜め斬り。</p></div>
                  <div class="howto-key"><span class="plat">PC</span><p><kbd>J</kbd> で斬撃、<kbd>K</kbd> で強攻撃。<kbd>K</kbd> 押しっぱなしで溜め斬り。</p></div>
                </div>
                <p class="howto-tip">上段=頭・腕狙い／中段=胴狙い／下段=足狙い。最大まで溜めた一撃は四肢を断ち飛ばしますが、溜めるほどカウンターの的に。振りかぶりはガードで寸止め（フェイント）、ステップで仕切り直しできます。</p>
              </div>
            </div>

            <div class="howto-row">
              <span class="howto-icon">🛡️</span>
              <div class="howto-body">
                <h3>ガード・弾き</h3>
                <div class="howto-keys">
                  <div class="howto-key"><span class="plat">スマホ</span><p>「防」長押しでガード。当たる直前に押すと<strong>弾き</strong>。</p></div>
                  <div class="howto-key"><span class="plat">PC</span><p><kbd>L</kbd> 長押しでガード。直前押しで弾き。</p></div>
                </div>
                <p class="howto-tip">ガードは構えの段に関係なく受けられます。弾きは相手をよろけさせ、受け流し（当たる直前のステップ）は相手を前に泳がせて大きな隙を作ります。強攻撃だけはガードの上から体勢を崩されるので注意。</p>
              </div>
            </div>

            <div class="howto-row">
              <span class="howto-icon">⚡</span>
              <div class="howto-body">
                <h3>カウンター</h3>
                <div class="howto-keys">
                  <div class="howto-key"><span class="plat common">共通</span><p>敵の振りかぶりの終わり際、<strong>敵の頭上に ▼ が出た瞬間</strong>に斬撃。</p></div>
                </div>
                <p class="howto-tip">決まれば敵の攻撃を潰して、頭か胴への致命の一閃。逆にこちらが読まれると敵の見切りが白く閃きます——その刹那にステップすれば「見切り返し」で大きな隙を作れます。</p>
              </div>
            </div>

            <div class="howto-row">
              <span class="howto-icon">⚔</span>
              <div class="howto-body">
                <h3>武器を選ぶ</h3>
                <div class="howto-keys">
                  <div class="howto-key"><span class="plat common">共通</span><p>立ち合いの前に6種の得物から選択。敵の得物は毎回変わります。</p></div>
                </div>
                <div class="pups">
                  {weapons.map((w) => (
                    <span class="pup"><b>{w.k}</b>{w.label}</span>
                  ))}
                </div>
              </div>
            </div>

          </div>
        </section>

      </div>

      <section class="other" data-reveal>
        <h2>ほかの作品</h2>
        <div class="other-grid">
          {otherWorks.map((w) => (
            <a class="owork" href={`/works/${w.slug}`}>
              <span class="oi"><img src={w.icon} alt="" /></span>
              <span><b>{w.name}</b><span>{w.desc}</span></span>
            </a>
          ))}
        </div>
        <a class="back-link" href="/#works">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          Works に戻る
        </a>
      </section>

    </div>
  </section>
</BaseLayout>

<style is:global>
  .rank-lead { margin: 14px 0 18px; }

  /* ── 瓦版（和紙・墨枠・朱印） ── */
  .kwr {
    position: relative;
    padding: 26px 26px 22px;
    border: 3px double #3a332a;
    outline: 1px solid #3a332a;
    outline-offset: 3px;
    background:
      radial-gradient(ellipse 60% 40% at 18% 8%, rgba(118, 92, 46, 0.06), transparent 60%),
      radial-gradient(ellipse 50% 45% at 85% 92%, rgba(118, 92, 46, 0.09), transparent 60%),
      radial-gradient(ellipse 35% 30% at 70% 20%, rgba(255, 252, 244, 0.5), transparent 60%),
      linear-gradient(173deg, #f0e8d6 0%, #eae0ca 55%, #e4d8bf 100%);
    box-shadow: inset 0 0 42px rgba(94, 72, 36, 0.13), 0 2px 10px rgba(40, 32, 18, 0.18);
    color: #2e2a22;
  }
  .kwr-kicker {
    margin: 0; text-align: center; font-size: 12px; letter-spacing: 0.55em;
    color: #6b5f4a; font-family: 'Yuji Syuku', serif;
  }
  .kwr-title {
    margin: 4px 0 0; text-align: center; font-family: 'Yuji Syuku', serif;
    font-size: clamp(28px, 5vw, 40px); line-height: 1.2; color: #211d16;
  }
  .kwr-sub {
    margin: 2px 0 18px; text-align: center; font-size: 12.5px; color: #6b5f4a;
    letter-spacing: 0.18em; font-family: 'Yuji Syuku', serif;
    border-bottom: 1px solid rgba(58, 51, 42, 0.45); padding-bottom: 12px;
  }
  .kwr-seal {
    position: absolute; top: 16px; right: 18px;
    width: 40px; height: 40px; display: grid; place-items: center;
    font-family: 'Yuji Syuku', serif; font-size: 24px;
    color: #a23527; border: 2px solid #a23527; border-radius: 4px;
    transform: rotate(-5deg); opacity: 0.82;
  }

  .rank-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .rank-col { padding: 0 18px; min-width: 0; }
  .rank-col + .rank-col { border-left: 1px solid rgba(58, 51, 42, 0.4); }
  @media (max-width: 720px) {
    .rank-grid { grid-template-columns: 1fr; }
    .rank-col { padding: 0 2px; }
    .rank-col + .rank-col { border-left: 0; border-top: 1px solid rgba(58, 51, 42, 0.4); margin-top: 14px; padding-top: 14px; }
  }
  .rank-head { margin: 0 0 10px; text-align: center; }
  .rank-head span {
    display: inline-block; background: #2e2a22; color: #ece3cd;
    font-family: 'Yuji Syuku', serif; font-size: 15px; font-weight: 400;
    padding: 3px 16px 4px; letter-spacing: 0.3em; text-indent: 0.3em;
  }
  .rank-list { list-style: none; margin: 0; padding: 0; }
  .rank-list li {
    display: flex; align-items: baseline; gap: 10px; padding: 6.5px 2px;
    border-top: 1px dashed rgba(58, 51, 42, 0.35); font-size: 14.5px;
  }
  .rank-list li:first-child { border-top: 0; }
  .rank-no {
    width: 1.7em; text-align: center; font-family: 'Yuji Syuku', serif;
    color: #50483a;
  }
  .rank-name {
    flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    font-family: 'Yuji Syuku', serif; font-size: 16px; color: #211d16;
  }
  .rank-kills { font-weight: 700; color: #50483a; font-size: 13.5px; }
  .rank-list li.kwr-top { font-size: 16px; }
  .rank-list li.kwr-top .rank-no,
  .rank-list li.kwr-top .rank-name { color: #a23527; }
  .rank-list li.kwr-top .rank-name { font-size: 19px; }
  .rank-list li.kwr-top .rank-kills { color: #a23527; }
  .rank-list li.rank-empty {
    color: #6b5f4a; font-family: 'Yuji Syuku', serif;
    display: block; text-align: center;
    padding: 14px 0 8px; font-size: 14px;
  }
</style>

<script>
  function initZansetsuRanking() {
    const cols = document.querySelectorAll('.rank-col');
    if (!cols.length) return;
    const esc = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] ?? c);
    cols.forEach(async (col) => {
      const list = col.querySelector('.rank-list');
      if (!list) return;
      try {
        const res = await fetch(`https://zansetsu-rank.yamada2089.workers.dev/top?diff=${(col as HTMLElement).dataset.diff}`);
        const data = await res.json();
        const top = (data.top || []).slice(0, 10);
        const KAN = ['一', '二', '三', '四', '五', '六', '七', '八', '九', '十'];
        list.innerHTML = top.length
          ? top.map((e: { n: string; k: number }, i: number) =>
              `<li${i === 0 ? ' class="kwr-top"' : ''}><span class="rank-no">${KAN[i] ?? i + 1}</span><span class="rank-name">${esc(String(e.n))}</span><span class="rank-kills">${e.k | 0}人斬り</span></li>`
            ).join('')
          : '<li class="rank-empty">記録、未だ無し</li>';
      } catch {
        list.innerHTML = '<li class="rank-empty">瓦版屋が留守のようです</li>';
      }
    });
  }
  document.addEventListener('astro:page-load', initZansetsuRanking);
</script>
