---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/detail.css";
import { getCollection } from "astro:content";

// English version of the InkPress detail page. Mirrors works/inkpress.astro
// (same layout/styles) with English copy; the JA-only "dev log" article list
// is intentionally omitted. Title/storeUrl come from the content collection;
// the rest of the copy is authored here in English.
const apps = await getCollection("apps");
const app = apps.find((a) => a.slug === "inkpress")!;
const { data } = app;

const features = [
  { title: "Built for Android E-Ink devices", body: "Dithering, contrast tuning, and rendering matched to E-Ink ghosting and refresh speed. It aims for a paper-like reading feel across a range of Android E-Ink devices." },
  { title: "PDF, CBZ, CBR & images — all in one", body: "Opens PDF / ZIP / CBZ / RAR / CBR and image folders. Your scanned books and downloaded comics open directly, all in a single app." },
  { title: "Spreads, vertical scroll & RTL", body: "LTR, RTL (manga), vertical scroll (webtoon) and two-page spreads. Settings are inherited per folder, so you keep reading without readjusting every time." },
  { title: "Dropbox sync & handwritten notes", body: "Sync your reading position, notes and per-book settings across devices via Dropbox — pick up on your E-Ink device right where your phone left off. Leave handwritten notes, highlights and bookmarks on any page." },
];

// TODO: swap to English-localised screenshots when available (currently JA UI).
const shots = [
  { src: "/assets/apps/inkpress-onboarding.png", alt: "InkPress screenshot 1" },
  { src: "/assets/apps/inkpress-settings.png", alt: "InkPress screenshot 2" },
  { src: "/assets/apps/inkpress-reader-controls.png", alt: "InkPress screenshot 3" },
];

const otherWorks = [
  { slug: "playcord", name: "PLAYCORD", desc: "A realistic baseball life sim.", icon: "/assets/apps/playcord-icon.png" },
  { slug: "rainwiper", name: "RainWiper", desc: "Rain, on your browser.", icon: "/assets/apps/rainwiper-icon.png" },
  { slug: "cosmo-cleaner", name: "COSMO CLEANER", desc: "A CRT-style cosmic cleanup shooter.", icon: "/assets/apps/cosmo-cleaner-icon.png" },
];

const alternates = [
  { hreflang: "ja", href: "/works/inkpress" },
  { hreflang: "en", href: "/works/inkpress/en" },
  { hreflang: "x-default", href: "/works/inkpress" },
];
---

<BaseLayout
  title={`${data.title} — Y.M Apps`}
  description="A light, quiet reader for scanned books and comics on E-Ink devices."
  lang="en"
  alternates={alternates}
>
  <section class="stack-section">
    <div class="container detail-page">

      <p class="lang-switch"><a href="/works/inkpress">日本語</a></p>

      <nav class="crumb">
        <a href="/">Home</a><span class="sep">/</span>
        <a href="/#works">Works</a><span class="sep">/</span>
        <span class="cur">{data.title}</span>
      </nav>

      <section class="detail-hero" data-reveal>
        <div class="hero-banner">
          {/* TODO: swap to an English hero banner when available (text is JA). */}
          <img src="/assets/hero/inkpress-hero.png" alt="InkPress — a light, quiet reader for scanned books" />
        </div>
        <div class="card meta-bar">
          <div class="mb-status"><span class="badge-live">Live on Google Play</span></div>
          <div class="mb-chips">
            <span class="chip">Android</span>
            <span class="chip">v1.2.4</span>
            <span class="chip">Free</span>
            <span class="chip chip-gold">Reading app</span>
          </div>
          <div class="mb-actions">
            <a class="btn btn-primary" href={data.storeUrl} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 3l14 9-14 9V3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path></svg>
              View on Google Play
            </a>
          </div>
        </div>
      </section>

      <div class="detail-body">

        <section class="block" data-reveal>
          <span class="lede">ABOUT</span>
          <h2>About</h2>
          <div class="about-text">
            <p>I love reading on E-Ink devices, and I built InkPress because I wanted a reader that finally felt right to me.</p>
            <p class="pull">PDFs and scanned comics that open as easily as a paper book — that's the quiet little tool I'm aiming for.</p>
            <p>I've been building it bit by bit since last year, and it's finally out. No ads, completely free, with every feature included.</p>
          </div>
        </section>

        <section class="block" data-reveal>
          <span class="lede">FEATURES</span>
          <h2>Features</h2>
          <div class="features">
            {features.map((f, i) => (
              <div class="feature">
                <span class="fnum">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{f.title}</h3>
                  <p>{f.body}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="block" data-reveal>
          <span class="lede">SCREENS</span>
          <h2>Screenshots</h2>
          <div class="shots">
            {shots.map((s) => (
              <a class="shot" href={s.src} target="_blank" rel="noopener noreferrer"><img src={s.src} alt={s.alt} loading="lazy" decoding="async" /></a>
            ))}
          </div>
        </section>

      </div>

      <section class="other" data-reveal>
        <h2>More works</h2>
        <div class="other-grid">
          {otherWorks.map((w) => (
            <a class="owork" href={`/works/${w.slug}`}>
              <span class="oi"><img src={w.icon} alt="" /></span>
              <span><b>{w.name}</b><span>{w.desc}</span></span>
            </a>
          ))}
        </div>
        <a class="back-link" href="/#works">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          Back to Works
        </a>
      </section>

    </div>
  </section>
</BaseLayout>

<style>
  .lang-switch { text-align: right; font-size: 12px; font-weight: 700; margin: 0 0 6px; }
  .lang-switch a { color: var(--ink-3); }
  .lang-switch a:hover { color: var(--ink); text-decoration: none; }
</style>
