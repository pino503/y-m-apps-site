---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import "../styles/world-themes.css";
// Claude Design system — loaded last so its warm tokens, Zen fonts and
// header/footer/button styles win site-wide over the older global.css.
import "../styles/site.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  alternates?: { hreflang: string; href: string }[];
}

const {
  title = "Y.M Apps — 暮らしに溶ける、小さな道具",
  description = "PINO が個人で作っているアプリ・拡張機能・Webゲーム・LINEスタンプの公式サイト。InkPress / PLAYCORD / RainWiper / Sidewalk Defender / COSMO CLEANER / LINEスタンプと絵文字。",
  ogImage = "/assets/hero/poster-1120.png",
  lang = "ja",
  alternates = [],
} = Astro.props;

const siteName = "Y.M Apps";
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={new URL(a.href, Astro.site).href} />
    ))}
    <meta name="theme-color" content="#efe6d3" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=Shippori+Mincho+B1:wght@600;700;800&family=DotGothic16&display=swap" rel="stylesheet" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main id="main"><slot /></main>
    <Footer />

    <!-- back to top (appears after scrolling; persists across page transitions) -->
    <button id="to-top" class="to-top" type="button" aria-label="ページの先頭へ戻る" title="先頭へ戻る" transition:persist>
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19V7M6 13l6-6 6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    </button>

    <!-- sound toggle (persists across page transitions) -->
    <button id="sound-toggle" class="sound-toggle" type="button" aria-pressed="true" aria-label="効果音の切り替え" title="効果音のオン / オフ" transition:persist>
      <span class="st-on" aria-hidden="true">🔊</span>
      <span class="st-off" aria-hidden="true">🔇</span>
    </button>

    <script>
      // ============================================================
      // Y.M Apps — interaction layer: tasteful UI sound + reveal + nav.
      // Built for Astro <ClientRouter />: delegated listeners live on
      // `document` (persists across view transitions); per-page setup
      // re-runs on `astro:page-load`.
      // ============================================================

      const Sound = (() => {
        let ctx: AudioContext | null = null;
        let muted = false;
        try { muted = localStorage.getItem("ym-sound") === "off"; } catch {}

        function ac(): AudioContext | null {
          if (muted) return null;
          if (!ctx) {
            try { ctx = new (window.AudioContext || (window as any).webkitAudioContext)(); } catch { return null; }
          }
          if (ctx && ctx.state === "suspended") ctx.resume().catch(() => {});
          return ctx;
        }

        // a soft, short voiced blip through a gentle lowpass
        function blip(freq: number, dur: number, type: OscillatorType, gain: number, slideTo?: number, when = 0) {
          const c = ac(); if (!c) return;
          const t = c.currentTime + when;
          const o = c.createOscillator(), g = c.createGain();
          const lp = c.createBiquadFilter(); lp.type = "lowpass"; lp.frequency.value = 5200;
          o.type = type; o.frequency.setValueAtTime(freq, t);
          if (slideTo) o.frequency.exponentialRampToValueAtTime(slideTo, t + dur);
          g.gain.setValueAtTime(0.0001, t);
          g.gain.exponentialRampToValueAtTime(gain, t + 0.008);
          g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
          o.connect(g).connect(lp).connect(c.destination);
          o.start(t); o.stop(t + dur + 0.02);
        }

        // --- real audio files (mp3) — respects mute ---
        const PRESS_SRC = "/assets/audio/decision.mp3";
        const SHAKE_SRC = "/assets/audio/omikuji-shake.mp3"; // おみくじを振る音（このファイルを置けば鳴る）
        const pressPool: HTMLAudioElement[] = [];
        try { for (let i = 0; i < 4; i++) { const a = new Audio(PRESS_SRC); a.preload = "auto"; a.volume = 0.55; pressPool.push(a); } } catch {}
        let pressIdx = 0;
        let shakeEl: HTMLAudioElement | null = null;
        try { shakeEl = new Audio(SHAKE_SRC); shakeEl.preload = "auto"; shakeEl.volume = 0.5; } catch {}
        function playFile(a: HTMLAudioElement | null) {
          if (muted || !a) return;
          try { a.currentTime = 0; const p = a.play(); if (p && (p as any).catch) (p as any).catch(() => {}); } catch {}
        }

        let lastTick = 0;
        return {
          tick() { const now = performance.now(); if (now - lastTick < 45) return; lastTick = now; blip(1760 + Math.random() * 120, 0.03, "triangle", 0.018, 2100); },
          pop()  { blip(420, 0.10, "sine", 0.05, 680); blip(880, 0.07, "triangle", 0.022, 1180, 0.01); },
          chime(good = 0) {
            const base = [523.25, 659.25, 783.99, 1046.5];
            const n = good >= 2 ? 4 : good >= 1 ? 3 : 2;
            for (let i = 0; i < n; i++) blip(base[i], 0.22, "triangle", 0.05, base[i] * 1.5, i * 0.085);
          },
          press() { if (muted || !pressPool.length) return; const a = pressPool[pressIdx]; pressIdx = (pressIdx + 1) % pressPool.length; playFile(a); },
          shake() {
            if (muted || !shakeEl) return;
            const el = shakeEl;
            try { clearTimeout((el as any)._fadeTo); clearInterval((el as any)._fadeIv); } catch {}
            try { el.currentTime = 0; el.volume = 0.5; const p = el.play(); if (p && (p as any).catch) (p as any).catch(() => {}); } catch {}
            // 箱を振るアニメ(0.66s)に合わせて短く: ~0.5s からフェードして ~0.6s で停止
            (el as any)._fadeTo = setTimeout(() => {
              (el as any)._fadeIv = setInterval(() => {
                el.volume = Math.max(0, el.volume - 0.1);
                if (el.volume <= 0.001) { try { clearInterval((el as any)._fadeIv); el.pause(); el.currentTime = 0; el.volume = 0.5; } catch {} }
              }, 18);
            }, 500);
          },
          enabled() { return !muted; },
          toggle() {
            muted = !muted;
            try { localStorage.setItem("ym-sound", muted ? "off" : "on"); } catch {}
            if (!muted) this.press();
            return !muted;
          },
        };
      })();

      (window as any).ymSfx = Sound;

      // elements that should feel "alive" (hover tick + click pop)
      const INTERACTIVE = "a, button, .work-row, .featured-card, .tag, summary, [data-sfx]";
      function isInteractive(el: Element | null): Element | null {
        return el ? ((el as HTMLElement).closest?.(INTERACTIVE) ?? null) : null;
      }

      // --- delegated listeners (attach once; survive view transitions) ---
      let hoverLast: Element | null = null;
      document.addEventListener("pointerover", (e) => {
        if ((e as PointerEvent).pointerType === "touch") return;
        const el = isInteractive(e.target as Element);
        if (el && el !== hoverLast) { hoverLast = el; Sound.tick(); }
      });
      document.addEventListener("pointerout", (e) => {
        const el = isInteractive(e.target as Element);
        if (el === hoverLast) hoverLast = null;
      });
      document.addEventListener("pointerdown", (e) => {
        if ((e.target as Element)?.closest?.("#sound-toggle")) return;
        if (isInteractive(e.target as Element)) Sound.press();
      });

      // sound toggle
      function syncToggle() {
        const btn = document.getElementById("sound-toggle");
        if (!btn) return;
        const on = Sound.enabled();
        btn.setAttribute("aria-pressed", String(on));
        btn.classList.toggle("is-muted", !on);
      }
      document.addEventListener("click", (e) => {
        const btn = (e.target as Element)?.closest?.("#sound-toggle");
        if (!btn) return;
        Sound.toggle();
        syncToggle();
      });

      // back-to-top: show after scrolling, smooth-scroll to the top on click
      document.addEventListener("click", (e) => {
        if ((e.target as Element)?.closest?.("#to-top")) window.scrollTo({ top: 0, behavior: "smooth" });
      });
      const toTopBtn = document.getElementById("to-top");
      function syncToTop() { if (toTopBtn) toTopBtn.classList.toggle("show", window.scrollY > 500); }
      window.addEventListener("scroll", syncToTop, { passive: true });
      syncToTop();

      // smooth scroll for in-page anchors (delegated)
      document.addEventListener("click", (e) => {
        const a = (e.target as Element)?.closest?.('a[href^="#"]') as HTMLAnchorElement | null;
        if (!a) return;
        const id = a.getAttribute("href")?.slice(1);
        if (!id) return;
        const target = document.getElementById(id);
        if (target) { e.preventDefault(); target.scrollIntoView({ behavior: "smooth", block: "start" }); }
      });

      // --- per-page setup (re-runs after every view transition) ---
      let revealObserver: IntersectionObserver | null = null;
      function setupReveals() {
        if (revealObserver) revealObserver.disconnect();
        revealObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) { entry.target.classList.add("is-visible"); revealObserver!.unobserve(entry.target); }
            }
          },
          { rootMargin: "0px 0px -6% 0px", threshold: 0.01 }
        );
        document.querySelectorAll("[data-reveal]:not(.is-visible), .reveal:not(.is-visible)").forEach((el) => revealObserver!.observe(el));
      }

      // pointer-follow sheen on cards (sets --mx/--my for a soft highlight)
      function setupSheen() {
        document.querySelectorAll<HTMLElement>("[data-sheen]").forEach((card) => {
          if ((card as any)._sheen) return; (card as any)._sheen = true;
          card.addEventListener("pointermove", (ev) => {
            const r = card.getBoundingClientRect();
            card.style.setProperty("--mx", `${((ev.clientX - r.left) / r.width) * 100}%`);
            card.style.setProperty("--my", `${((ev.clientY - r.top) / r.height) * 100}%`);
          });
        });
      }

      // Japanese-aware wrapping: only allow line breaks AFTER punctuation so a
      // phrase like 「軽い気持ちでどうぞ。」 never splits into a lonely 「ぞ」.
      // (text-wrap:pretty doesn't fix short CJK orphans.) word-break:keep-all
      // blocks arbitrary CJK breaks; <wbr> after 、。!? re-adds phrase breaks.
      function phraseWrap(el: Element | null) {
        if (!el || (el as any)._pw) return;
        if ((el.textContent || "").length < 4) return;
        (el as any)._pw = true;
        (el as HTMLElement).style.wordBreak = "keep-all";
        (el as HTMLElement).style.overflowWrap = "anywhere"; // safety: break a too-long phrase if needed
        // walk only TEXT nodes so manual <br> (and other markup) is preserved
        for (const node of Array.from(el.childNodes)) {
          if (node.nodeType !== Node.TEXT_NODE) continue;
          const t = node.textContent || "";
          const parts = t.split(/(?<=[、。，．！？!?])/);
          if (parts.length < 2) continue;
          const frag = document.createDocumentFragment();
          parts.forEach((p, i) => {
            if (p) frag.appendChild(document.createTextNode(p));
            if (i < parts.length - 1) frag.appendChild(document.createElement("wbr"));
          });
          el.replaceChild(frag, node);
        }
      }
      (window as any).ymNoOrphan = (el: Element) => { if (el) { (el as any)._pw = false; phraseWrap(el); } };
      function bindOrphans() {
        // real text blocks on the page — phrase-aware wrapping (break after 、。
        // not mid-phrase) so Japanese lines never orphan a lone character
        document.querySelectorAll(".sec-sub, .feat-main p, .feat-side p, .omi-lead, .about-body p, .copy-hint")
          .forEach((el) => phraseWrap(el));
      }

      // 本文の改行は CSS の text-wrap:balance に一本化（旧 phrase-wrap は不使用）
      function onPageLoad() { setupReveals(); setupSheen(); syncToggle(); }
      document.addEventListener("astro:page-load", onPageLoad);
      if (document.readyState !== "loading") onPageLoad();
      else document.addEventListener("DOMContentLoaded", onPageLoad);
    </script>
  </body>
</html>
